//@version=6
// SMC / ICT Professional Indicator
// BOS, Auto Fib, Premium/Discount, FVG, Entry/SL/TP, RR Box
// Non-repainting | Latest Fib only | One setup per BOS
indicator(title = "SMC ICT Pro", shorttitle = "SMC ICT", overlay = true, max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)

// =============================================================================
// INPUTS
// =============================================================================
grpStruct   = "Structure"
swingLength = input.int(10, "Swing Length", minval = 2, maxval = 100, group = grpStruct)
pivotLength = input.int(5, "Pivot Length", minval = 2, maxval = 50, group = grpStruct)

grpDisplay     = "Display"
showFib        = input.bool(true, "Show Fibonacci", group = grpDisplay)
showFVG        = input.bool(true, "Show FVG", group = grpDisplay)
showPremDisc   = input.bool(true, "Show Premium / Discount", group = grpDisplay)
showBOS        = input.bool(true, "Show BOS", group = grpDisplay)
showTradeBox   = input.bool(true, "Show Risk / Reward Box", group = grpDisplay)
showEntryLines = input.bool(true, "Show Entry / SL / TP", group = grpDisplay)
extendFibBars  = input.int(40, "Fib / Zone Extend (bars)", minval = 5, maxval = 500, group = grpDisplay)

grpFilters  = "Filters"
atrLength   = input.int(14, "ATR Length", minval = 1, group = grpFilters)
minBodyPct  = input.float(10.0, "Minimum Body %", minval = 0.0, maxval = 100.0, step = 0.5, group = grpFilters)
minFvgSize  = input.float(0.0, "Minimum FVG Size", minval = 0.0, step = 0.0001, group = grpFilters)
atrFvgMult  = input.float(0.1, "ATR FVG Size Mult", minval = 0.0, step = 0.05, group = grpFilters)
ignoreDoji  = input.bool(true, "Ignore Doji Candles", group = grpFilters)
dojiBodyPct = input.float(5.0, "Doji Body % Threshold", minval = 0.0, maxval = 50.0, step = 0.5, group = grpFilters)

grpTrade      = "Trade Settings"
riskReward    = input.float(3.0, "Risk Reward", minval = 0.5, step = 0.1, group = grpTrade)
boxExtendBars = input.int(25, "Trade Box Width (bars)", minval = 5, maxval = 200, group = grpTrade)

grpColors      = "Colors"
bosBullColor   = input.color(color.new(#26A69A, 0), "BOS Bullish", group = grpColors)
bosBearColor   = input.color(color.new(#EF5350, 0), "BOS Bearish", group = grpColors)
fibColor       = input.color(color.new(#787B86, 30), "Fibonacci Lines", group = grpColors)
discountColor  = input.color(color.new(#26A69A, 85), "Discount Zone", group = grpColors)
premiumColor   = input.color(color.new(#EF5350, 85), "Premium Zone", group = grpColors)
fvgBullColor   = input.color(color.new(#26A69A, 75), "Bullish FVG", group = grpColors)
fvgBearColor   = input.color(color.new(#EF5350, 75), "Bearish FVG", group = grpColors)
entryColor     = input.color(color.new(#2196F3, 0), "Entry Line", group = grpColors)
slColor        = input.color(color.new(#EF5350, 0), "Stop Loss Line", group = grpColors)
tpColor        = input.color(color.new(#26A69A, 0), "Take Profit Line", group = grpColors)
riskBoxColor   = input.color(color.new(#EF5350, 80), "Risk Box", group = grpColors)
rewardBoxColor = input.color(color.new(#26A69A, 80), "Reward Box", group = grpColors)

grpAlerts = "Alerts"
alertsOn  = input.bool(true, "Alerts ON/OFF", group = grpAlerts)

// =============================================================================
// HELPERS
// =============================================================================
f_range(float h, float l) =>
    math.max(h - l, syminfo.mintick)

f_bodyPct(float o, float c, float h, float l) =>
    math.abs(c - o) / f_range(h, l) * 100.0

f_isWeak(float o, float c, float h, float l) =>
    (ignoreDoji and f_bodyPct(o, c, h, l) <= dojiBodyPct) or f_bodyPct(o, c, h, l) < minBodyPct

f_fib(float p0, float p1, float lvl) =>
    p0 + (p1 - p0) * lvl

f_clearLines(array<line> arr) =>
    int n = array.size(arr)
    if n > 0
        for i = 0 to n - 1
            line.delete(array.get(arr, i))
        array.clear(arr)

f_clearBoxes(array<box> arr) =>
    int n = array.size(arr)
    if n > 0
        for i = 0 to n - 1
            box.delete(array.get(arr, i))
        array.clear(arr)

f_clearLabels(array<label> arr) =>
    int n = array.size(arr)
    if n > 0
        for i = 0 to n - 1
            label.delete(array.get(arr, i))
        array.clear(arr)

// =============================================================================
// SERIES / FILTERS
// =============================================================================
atrValue  = ta.atr(atrLength)
isWeakNow = f_isWeak(open, close, high, low)

f_gapOk(float gapSize) =>
    gapSize > 0 and gapSize >= minFvgSize and gapSize >= atrValue * atrFvgMult

f_bullFvgOk() =>
    f_gapOk(low - high[2]) and not f_isWeak(open[2], close[2], high[2], low[2]) and not f_isWeak(open, close, high, low)

f_bearFvgOk() =>
    f_gapOk(low[2] - high) and not f_isWeak(open[2], close[2], high[2], low[2]) and not f_isWeak(open, close, high, low)

// =============================================================================
// CONFIRMED PIVOTS (non-repainting)
// =============================================================================
ph = ta.pivothigh(high, pivotLength, pivotLength)
pl = ta.pivotlow(low, pivotLength, pivotLength)

var float lastSH = na
var int   lastSHBar = na
var float lastSL = na
var int   lastSLBar = na
var float prevSH = na
var int   prevSHBar = na
var float prevSL = na
var int   prevSLBar = na

if not na(ph)
    prevSH := lastSH
    prevSHBar := lastSHBar
    lastSH := ph
    lastSHBar := bar_index - pivotLength

if not na(pl)
    prevSL := lastSL
    prevSLBar := lastSLBar
    lastSL := pl
    lastSLBar := bar_index - pivotLength

// =============================================================================
// BREAK OF STRUCTURE
// =============================================================================
var float brokenLvl = na
var int   brokenDir = 0

bullBOS = false
bearBOS = false

if barstate.isconfirmed and not isWeakNow
    if not na(lastSH) and close > lastSH and (brokenDir != 1 or brokenLvl != lastSH)
        bullBOS := true
    if not na(lastSL) and close < lastSL and (brokenDir != -1 or brokenLvl != lastSL)
        bearBOS := true

// =============================================================================
// SETUP STATE
// =============================================================================
var int   setupState = 0
var int   setupDir = 0
var float fib0 = na
var float fib1 = na
var int   fibStartBar = na
var float lvl05 = na
var float lvl15 = na
var bool  firstPullback = false
var bool  usedFvg = false
var bool  usedTrade = false
var float fvgTop = na
var float fvgBot = na
var float entryPrice = na
var float stopPrice = na
var float tpPrice = na
var int   entryBar = na
var bool  tradeActive = false
var float bosLevel = na

var array<line> fibLines = array.new<line>()
var array<label> fibLabels = array.new<label>()
var array<box> zoneBoxes = array.new<box>()
var array<box> fvgBoxes = array.new<box>()
var array<label> bosLabels = array.new<label>()
var array<line> bosLines = array.new<line>()

var line entryLine = na
var line slLine = na
var line tpLine = na
var box riskBoxObj = na
var box rewardBoxObj = na
var label tradeLabel = na
var label entryLbl = na
var label slLbl = na
var label tpLbl = na

alertBullBOS = false
alertBearBOS = false
alertBullFVG = false
alertBearFVG = false
alertBuyReady = false
alertSellReady = false
alertTP = false
alertSL = false

// Fib levels used every BOS
fibLevels = array.from(0.0, 0.236, 0.382, 0.5, 0.618, 0.705, 0.786, 1.0, 1.5)

// =============================================================================
// CLEAR / DRAW (local scope only uses object delete; globals reassigned outside)
// =============================================================================
f_wipeTradeDrawings() =>
    if not na(entryLine)
        line.delete(entryLine)
    if not na(slLine)
        line.delete(slLine)
    if not na(tpLine)
        line.delete(tpLine)
    if not na(riskBoxObj)
        box.delete(riskBoxObj)
    if not na(rewardBoxObj)
        box.delete(rewardBoxObj)
    if not na(tradeLabel)
        label.delete(tradeLabel)
    if not na(entryLbl)
        label.delete(entryLbl)
    if not na(slLbl)
        label.delete(slLbl)
    if not na(tpLbl)
        label.delete(tpLbl)

f_wipeAllSetupDrawings() =>
    f_clearLines(fibLines)
    f_clearLabels(fibLabels)
    f_clearBoxes(zoneBoxes)
    f_clearBoxes(fvgBoxes)
    f_wipeTradeDrawings()

f_drawFib(float p0, float p1, int startBar) =>
    f_clearLines(fibLines)
    f_clearLabels(fibLabels)
    f_clearBoxes(zoneBoxes)
    int right = startBar + extendFibBars
    if showFib
        for i = 0 to array.size(fibLevels) - 1
            float lvl = array.get(fibLevels, i)
            float px = f_fib(p0, p1, lvl)
            color lc = lvl == 0.5 ? color.new(#FFD54F, 0) : lvl == 1.5 ? slColor : fibColor
            int w = (lvl == 0.0 or lvl == 0.5 or lvl == 1.0 or lvl == 1.5) ? 2 : 1
            array.push(fibLines, line.new(startBar, px, right, px, color = lc, style = (lvl == 0.5 or lvl == 1.5) ? line.style_solid : line.style_dashed, width = w))
            array.push(fibLabels, label.new(right, px, str.tostring(lvl, "#.###"), style = label.style_label_left, color = color.new(color.black, 100), textcolor = lc, size = size.small))
    if showPremDisc
        float mid = f_fib(p0, p1, 0.5)
        float top = math.max(p0, p1)
        float bot = math.min(p0, p1)
        array.push(zoneBoxes, box.new(startBar, top, right, mid, bgcolor = premiumColor, border_color = color.new(premiumColor, 50), border_width = 1))
        array.push(zoneBoxes, box.new(startBar, mid, right, bot, bgcolor = discountColor, border_color = color.new(discountColor, 50), border_width = 1))
        array.push(fibLabels, label.new(startBar, (top + mid) / 2.0, "Premium", style = label.style_label_right, color = color.new(color.black, 100), textcolor = color.new(#EF5350, 20), size = size.small))
        array.push(fibLabels, label.new(startBar, (mid + bot) / 2.0, "Discount", style = label.style_label_right, color = color.new(color.black, 100), textcolor = color.new(#26A69A, 20), size = size.small))

f_drawBos(bool isBull, float level) =>
    if showBOS
        color c = isBull ? bosBullColor : bosBearColor
        array.push(bosLabels, label.new(bar_index, level, isBull ? "BOS" : "BOS", style = isBull ? label.style_label_down : label.style_label_up, color = c, textcolor = color.white, size = size.small))
        if array.size(bosLabels) > 20
            label.delete(array.shift(bosLabels))
        array.push(bosLines, line.new(bar_index - 1, level, bar_index + 3, level, color = c, style = line.style_dotted, width = 2))
        if array.size(bosLines) > 20
            line.delete(array.shift(bosLines))

f_findBullSwings() =>
    float sh = lastSH
    int shB = lastSHBar
    float sl = lastSL
    int slB = lastSLBar
    if not na(sh) and not na(sl) and slB >= shB
        if not na(prevSL) and prevSLBar < shB
            sl := prevSL
            slB := prevSLBar
        else
            float tmpLow = low
            int tmpBar = bar_index
            int maxI = math.min(swingLength * 8, bar_index)
            if maxI >= pivotLength
                for i = pivotLength to maxI
                    int b = bar_index - i
                    if b < shB and low[i] <= tmpLow
                        tmpLow := low[i]
                        tmpBar := b
            sl := tmpLow
            slB := tmpBar
    [sh, shB, sl, slB]

f_findBearSwings() =>
    float sh = lastSH
    int shB = lastSHBar
    float sl = lastSL
    int slB = lastSLBar
    if not na(sh) and not na(sl) and shB >= slB
        if not na(prevSH) and prevSHBar < slB
            sh := prevSH
            shB := prevSHBar
        else
            float tmpHigh = high
            int tmpBar = bar_index
            int maxI = math.min(swingLength * 8, bar_index)
            if maxI >= pivotLength
                for i = pivotLength to maxI
                    int b = bar_index - i
                    if b < slB and high[i] >= tmpHigh
                        tmpHigh := high[i]
                        tmpBar := b
            sh := tmpHigh
            shB := tmpBar
    [sh, shB, sl, slB]

// =============================================================================
// NEW BOS
// =============================================================================
if barstate.isconfirmed and (bullBOS or bearBOS)
    f_wipeAllSetupDrawings()
    entryLine := na
    slLine := na
    tpLine := na
    riskBoxObj := na
    rewardBoxObj := na
    tradeLabel := na
    entryLbl := na
    slLbl := na
    tpLbl := na

    if bullBOS
        [sh, shB, sl, slB] = f_findBullSwings()
        if not na(sh) and not na(sl) and sh != sl
            brokenDir := 1
            brokenLvl := lastSH
            bosLevel := lastSH
            setupDir := 1
            fib0 := sh
            fib1 := sl
            fibStartBar := math.min(nz(shB, bar_index), nz(slB, bar_index))
            lvl05 := f_fib(fib0, fib1, 0.5)
            lvl15 := f_fib(fib0, fib1, 1.5)
            setupState := 1
            firstPullback := false
            usedFvg := false
            usedTrade := false
            tradeActive := false
            fvgTop := na
            fvgBot := na
            entryPrice := na
            stopPrice := na
            tpPrice := na
            entryBar := na
            f_drawFib(fib0, fib1, fibStartBar)
            f_drawBos(true, bosLevel)
            alertBullBOS := true

    if bearBOS and not bullBOS
        [sh, shB, sl, slB] = f_findBearSwings()
        if not na(sh) and not na(sl) and sh != sl
            brokenDir := -1
            brokenLvl := lastSL
            bosLevel := lastSL
            setupDir := -1
            fib0 := sl
            fib1 := sh
            fibStartBar := math.min(nz(shB, bar_index), nz(slB, bar_index))
            lvl05 := f_fib(fib0, fib1, 0.5)
            lvl15 := f_fib(fib0, fib1, 1.5)
            setupState := 1
            firstPullback := false
            usedFvg := false
            usedTrade := false
            tradeActive := false
            fvgTop := na
            fvgBot := na
            entryPrice := na
            stopPrice := na
            tpPrice := na
            entryBar := na
            f_drawFib(fib0, fib1, fibStartBar)
            f_drawBos(false, bosLevel)
            alertBearBOS := true

// =============================================================================
// SETUP LIFECYCLE
// =============================================================================
if barstate.isconfirmed and setupState > 0 and not na(fib0) and not na(fib1) and not na(lvl05)
    int rightEdge = math.max(bar_index + 2, nz(fibStartBar, bar_index) + extendFibBars)

    if showFib
        int nLines = array.size(fibLines)
        if nLines > 0
            for i = 0 to nLines - 1
                line.set_x2(array.get(fibLines, i), rightEdge)
        int nLabs = array.size(fibLabels)
        if nLabs > 0
            for i = 0 to nLabs - 1
                label lb = array.get(fibLabels, i)
                if label.get_x(lb) > nz(fibStartBar, bar_index)
                    label.set_x(lb, rightEdge)

    if showPremDisc
        int nZones = array.size(zoneBoxes)
        if nZones > 0
            for i = 0 to nZones - 1
                box.set_right(array.get(zoneBoxes, i), rightEdge)

    // Cancel if structure broken before entry
    if setupState >= 1 and setupState <= 2 and not tradeActive
        bool structBroken = setupDir == 1 ? close < fib1 : close > fib1
        if structBroken
            f_wipeAllSetupDrawings()
            entryLine := na
            slLine := na
            tpLine := na
            riskBoxObj := na
            rewardBoxObj := na
            tradeLabel := na
            entryLbl := na
            slLbl := na
            tpLbl := na
            setupState := 0
            tradeActive := false

    // First pullback only
    if setupState == 1 and not firstPullback
        bool touched50 = low <= lvl05 and high >= lvl05
        if setupDir == 1 and (low < lvl05 or touched50)
            firstPullback := true
            setupState := 2
        if setupDir == -1 and (high > lvl05 or touched50)
            firstPullback := true
            setupState := 2

    // One FVG per BOS -> entry / SL / TP / RR box
    if setupState == 2 and firstPullback and not usedFvg and not usedTrade
        if setupDir == 1 and f_bullFvgOk()
            float gapTop = low
            float gapBot = high[2]
            float midGap = (gapTop + gapBot) / 2.0
            bool zoneOk = midGap < lvl05 or math.abs(midGap - lvl05) <= atrValue * 0.25
            if zoneOk and low > gapBot
                fvgTop := gapTop
                fvgBot := gapBot
                usedFvg := true
                usedTrade := true
                entryPrice := midGap
                stopPrice := lvl15
                tpPrice := entryPrice + math.abs(entryPrice - stopPrice) * riskReward
                entryBar := bar_index
                if showFVG
                    array.push(fvgBoxes, box.new(bar_index - 2, gapTop, bar_index + extendFibBars, gapBot, bgcolor = fvgBullColor, border_color = color.new(#26A69A, 40), border_width = 1, text = "FVG", text_color = color.new(#26A69A, 0), text_size = size.tiny))
                f_wipeTradeDrawings()
                int right = entryBar + boxExtendBars
                float riskAmt = math.abs(entryPrice - stopPrice)
                float rewardAmt = math.abs(tpPrice - entryPrice)
                float riskPct = entryPrice != 0.0 ? riskAmt / entryPrice * 100.0 : 0.0
                float rewardPct = entryPrice != 0.0 ? rewardAmt / entryPrice * 100.0 : 0.0
                float rrActual = riskAmt != 0.0 ? rewardAmt / riskAmt : 0.0
                if showEntryLines
                    entryLine := line.new(entryBar, entryPrice, right, entryPrice, color = entryColor, width = 2)
                    slLine := line.new(entryBar, stopPrice, right, stopPrice, color = slColor, width = 2)
                    tpLine := line.new(entryBar, tpPrice, right, tpPrice, color = tpColor, width = 2)
                    entryLbl := label.new(right, entryPrice, "Entry " + str.tostring(entryPrice, format.mintick), style = label.style_label_left, color = entryColor, textcolor = color.white, size = size.small)
                    slLbl := label.new(right, stopPrice, "SL " + str.tostring(stopPrice, format.mintick), style = label.style_label_left, color = slColor, textcolor = color.white, size = size.small)
                    tpLbl := label.new(right, tpPrice, "TP " + str.tostring(tpPrice, format.mintick), style = label.style_label_left, color = tpColor, textcolor = color.white, size = size.small)
                if showTradeBox
                    riskBoxObj := box.new(entryBar, math.max(entryPrice, stopPrice), right, math.min(entryPrice, stopPrice), bgcolor = riskBoxColor, border_color = color.new(slColor, 40), border_width = 1)
                    rewardBoxObj := box.new(entryBar, math.max(entryPrice, tpPrice), right, math.min(entryPrice, tpPrice), bgcolor = rewardBoxColor, border_color = color.new(tpColor, 40), border_width = 1)
                    tradeLabel := label.new(entryBar + int(boxExtendBars * 0.35), (entryPrice + tpPrice) / 2.0, "LONG\nEntry: " + str.tostring(entryPrice, format.mintick) + "\nSL: " + str.tostring(stopPrice, format.mintick) + "\nTP: " + str.tostring(tpPrice, format.mintick) + "\nRisk: " + str.tostring(riskPct, "#.##") + "%\nReward: " + str.tostring(rewardPct, "#.##") + "%\nRR = 1:" + str.tostring(rrActual, "#.##"), style = label.style_label_center, color = color.new(color.black, 30), textcolor = color.white, size = size.normal)
                tradeActive := true
                setupState := 4
                alertBullFVG := true
                alertBuyReady := true

        if setupDir == -1 and f_bearFvgOk()
            float gapBot = high
            float gapTop = low[2]
            float midGap = (gapTop + gapBot) / 2.0
            bool zoneOk = midGap > lvl05 or math.abs(midGap - lvl05) <= atrValue * 0.25
            if zoneOk and high < gapTop
                fvgTop := gapTop
                fvgBot := gapBot
                usedFvg := true
                usedTrade := true
                entryPrice := midGap
                stopPrice := lvl15
                tpPrice := entryPrice - math.abs(entryPrice - stopPrice) * riskReward
                entryBar := bar_index
                if showFVG
                    array.push(fvgBoxes, box.new(bar_index - 2, gapTop, bar_index + extendFibBars, gapBot, bgcolor = fvgBearColor, border_color = color.new(#EF5350, 40), border_width = 1, text = "FVG", text_color = color.new(#EF5350, 0), text_size = size.tiny))
                f_wipeTradeDrawings()
                int right = entryBar + boxExtendBars
                float riskAmt = math.abs(entryPrice - stopPrice)
                float rewardAmt = math.abs(tpPrice - entryPrice)
                float riskPct = entryPrice != 0.0 ? riskAmt / entryPrice * 100.0 : 0.0
                float rewardPct = entryPrice != 0.0 ? rewardAmt / entryPrice * 100.0 : 0.0
                float rrActual = riskAmt != 0.0 ? rewardAmt / riskAmt : 0.0
                if showEntryLines
                    entryLine := line.new(entryBar, entryPrice, right, entryPrice, color = entryColor, width = 2)
                    slLine := line.new(entryBar, stopPrice, right, stopPrice, color = slColor, width = 2)
                    tpLine := line.new(entryBar, tpPrice, right, tpPrice, color = tpColor, width = 2)
                    entryLbl := label.new(right, entryPrice, "Entry " + str.tostring(entryPrice, format.mintick), style = label.style_label_left, color = entryColor, textcolor = color.white, size = size.small)
                    slLbl := label.new(right, stopPrice, "SL " + str.tostring(stopPrice, format.mintick), style = label.style_label_left, color = slColor, textcolor = color.white, size = size.small)
                    tpLbl := label.new(right, tpPrice, "TP " + str.tostring(tpPrice, format.mintick), style = label.style_label_left, color = tpColor, textcolor = color.white, size = size.small)
                if showTradeBox
                    riskBoxObj := box.new(entryBar, math.max(entryPrice, stopPrice), right, math.min(entryPrice, stopPrice), bgcolor = riskBoxColor, border_color = color.new(slColor, 40), border_width = 1)
                    rewardBoxObj := box.new(entryBar, math.max(entryPrice, tpPrice), right, math.min(entryPrice, tpPrice), bgcolor = rewardBoxColor, border_color = color.new(tpColor, 40), border_width = 1)
                    tradeLabel := label.new(entryBar + int(boxExtendBars * 0.35), (entryPrice + tpPrice) / 2.0, "SHORT\nEntry: " + str.tostring(entryPrice, format.mintick) + "\nSL: " + str.tostring(stopPrice, format.mintick) + "\nTP: " + str.tostring(tpPrice, format.mintick) + "\nRisk: " + str.tostring(riskPct, "#.##") + "%\nReward: " + str.tostring(rewardPct, "#.##") + "%\nRR = 1:" + str.tostring(rrActual, "#.##"), style = label.style_label_center, color = color.new(color.black, 30), textcolor = color.white, size = size.normal)
                tradeActive := true
                setupState := 4
                alertBearFVG := true
                alertSellReady := true

        // Ignore later pullbacks if price runs away without FVG
        if not usedFvg
            if setupDir == 1 and close > lvl05 and high >= fib0
                setupState := 5
            if setupDir == -1 and close < lvl05 and low <= fib0
                setupState := 5

    // Manage open setup
    if setupState == 4 and tradeActive and not na(entryPrice) and not na(stopPrice) and not na(tpPrice)
        int tRight = math.max(nz(entryBar, bar_index) + boxExtendBars, bar_index + 1)
        if not na(entryLine)
            line.set_x2(entryLine, tRight)
        if not na(slLine)
            line.set_x2(slLine, tRight)
        if not na(tpLine)
            line.set_x2(tpLine, tRight)
        if not na(riskBoxObj)
            box.set_right(riskBoxObj, tRight)
        if not na(rewardBoxObj)
            box.set_right(rewardBoxObj, tRight)
        if not na(entryLbl)
            label.set_x(entryLbl, tRight)
        if not na(slLbl)
            label.set_x(slLbl, tRight)
        if not na(tpLbl)
            label.set_x(tpLbl, tRight)

        if showFVG and array.size(fvgBoxes) > 0 and not na(fvgTop) and not na(fvgBot)
            if setupDir == 1 and low <= fvgBot
                box.set_bgcolor(array.get(fvgBoxes, array.size(fvgBoxes) - 1), color.new(color.gray, 90))
            if setupDir == -1 and high >= fvgTop
                box.set_bgcolor(array.get(fvgBoxes, array.size(fvgBoxes) - 1), color.new(color.gray, 90))

        if setupDir == 1
            if high >= tpPrice
                alertTP := true
                tradeActive := false
                setupState := 5
                if not na(tradeLabel)
                    label.set_text(tradeLabel, label.get_text(tradeLabel) + "\nTP HIT")
            else if low <= stopPrice
                alertSL := true
                tradeActive := false
                setupState := 5
                if not na(tradeLabel)
                    label.set_text(tradeLabel, label.get_text(tradeLabel) + "\nSL HIT")
        if setupDir == -1
            if low <= tpPrice
                alertTP := true
                tradeActive := false
                setupState := 5
                if not na(tradeLabel)
                    label.set_text(tradeLabel, label.get_text(tradeLabel) + "\nTP HIT")
            else if high >= stopPrice
                alertSL := true
                tradeActive := false
                setupState := 5
                if not na(tradeLabel)
                    label.set_text(tradeLabel, label.get_text(tradeLabel) + "\nSL HIT")

// =============================================================================
// HUD
// =============================================================================
var table hud = table.new(position.top_right, 2, 6, bgcolor = color.new(#131722, 20), border_color = color.new(#787B86, 50), border_width = 1)

if barstate.islast
    string stTxt = setupState == 0 ? "Idle" : setupState == 1 ? "Wait Pullback" : setupState == 2 ? "Search FVG" : setupState == 4 ? "In Trade" : setupState == 5 ? "Complete" : "-"
    string dirTxt = setupDir == 1 ? "Bullish" : setupDir == -1 ? "Bearish" : "-"
    string zoneTxt = na(lvl05) ? "-" : close < lvl05 ? "Discount" : close > lvl05 ? "Premium" : "EQ"
    table.cell(hud, 0, 0, "SMC ICT Pro", text_color = color.white, text_size = size.small)
    table.cell(hud, 1, 0, "", text_color = color.white)
    table.cell(hud, 0, 1, "Bias", text_color = color.gray, text_size = size.tiny)
    table.cell(hud, 1, 1, dirTxt, text_color = setupDir == 1 ? bosBullColor : setupDir == -1 ? bosBearColor : color.gray, text_size = size.small)
    table.cell(hud, 0, 2, "State", text_color = color.gray, text_size = size.tiny)
    table.cell(hud, 1, 2, stTxt, text_color = color.white, text_size = size.small)
    table.cell(hud, 0, 3, "Zone", text_color = color.gray, text_size = size.tiny)
    table.cell(hud, 1, 3, zoneTxt, text_color = zoneTxt == "Discount" ? bosBullColor : zoneTxt == "Premium" ? bosBearColor : color.gray, text_size = size.small)
    table.cell(hud, 0, 4, "RR", text_color = color.gray, text_size = size.tiny)
    table.cell(hud, 1, 4, "1:" + str.tostring(riskReward, "#.##"), text_color = color.white, text_size = size.small)
    table.cell(hud, 0, 5, "ATR", text_color = color.gray, text_size = size.tiny)
    table.cell(hud, 1, 5, str.tostring(atrValue, format.mintick), text_color = color.white, text_size = size.small)

// =============================================================================
// VISUAL OUTPUTS (required by TradingView CE10246)
// =============================================================================
plotshape(showBOS and bullBOS, title = "Bullish BOS", style = shape.triangleup, location = location.belowbar, color = bosBullColor, size = size.tiny)
plotshape(showBOS and bearBOS, title = "Bearish BOS", style = shape.triangledown, location = location.abovebar, color = bosBearColor, size = size.tiny)
plot(lvl05, "EQ 0.5", color = color.new(#FFD54F, 0), linewidth = 1, style = plot.style_linebr)
plot(entryPrice, "Entry", color = entryColor, linewidth = 1, style = plot.style_linebr)
plot(stopPrice, "Stop", color = slColor, linewidth = 1, style = plot.style_linebr)
plot(tpPrice, "TP", color = tpColor, linewidth = 1, style = plot.style_linebr)

// =============================================================================
// ALERTS
// =============================================================================
alertcondition(alertsOn and alertBullBOS, title = "Bullish BOS", message = "SMC ICT: Bullish Break of Structure")
alertcondition(alertsOn and alertBearBOS, title = "Bearish BOS", message = "SMC ICT: Bearish Break of Structure")
alertcondition(alertsOn and alertBullFVG, title = "Bullish FVG", message = "SMC ICT: Bullish Fair Value Gap detected")
alertcondition(alertsOn and alertBearFVG, title = "Bearish FVG", message = "SMC ICT: Bearish Fair Value Gap detected")
alertcondition(alertsOn and alertBuyReady, title = "Buy Entry Ready", message = "SMC ICT: Buy entry ready at FVG midpoint")
alertcondition(alertsOn and alertSellReady, title = "Sell Entry Ready", message = "SMC ICT: Sell entry ready at FVG midpoint")
alertcondition(alertsOn and alertTP, title = "Take Profit Hit", message = "SMC ICT: Take Profit hit")
alertcondition(alertsOn and alertSL, title = "Stop Loss Hit", message = "SMC ICT: Stop Loss hit")

if alertsOn and barstate.isconfirmed
    if alertBullBOS
        alert("SMC ICT | Bullish BOS @ " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
    if alertBearBOS
        alert("SMC ICT | Bearish BOS @ " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
    if alertBullFVG
        alert("SMC ICT | Bullish FVG | Entry " + str.tostring(entryPrice, format.mintick), alert.freq_once_per_bar_close)
    if alertBearFVG
        alert("SMC ICT | Bearish FVG | Entry " + str.tostring(entryPrice, format.mintick), alert.freq_once_per_bar_close)
    if alertBuyReady
        alert("SMC ICT | BUY READY | Entry " + str.tostring(entryPrice, format.mintick) + " | SL " + str.tostring(stopPrice, format.mintick) + " | TP " + str.tostring(tpPrice, format.mintick), alert.freq_once_per_bar_close)
    if alertSellReady
        alert("SMC ICT | SELL READY | Entry " + str.tostring(entryPrice, format.mintick) + " | SL " + str.tostring(stopPrice, format.mintick) + " | TP " + str.tostring(tpPrice, format.mintick), alert.freq_once_per_bar_close)
    if alertTP
        alert("SMC ICT | TAKE PROFIT HIT @ " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
    if alertSL
        alert("SMC ICT | STOP LOSS HIT @ " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
