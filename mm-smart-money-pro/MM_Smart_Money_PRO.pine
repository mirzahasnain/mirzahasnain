// ============================================================================
// MM Smart Money PRO
// ----------------------------------------------------------------------------
// Institutional-grade Smart Money Concepts engine (original implementation).
//
// Build status:
//   [x] Module 1 — Structure Engine (fractal-based)
//   [x] Module 2 — Liquidity Engine                 ← active
//   [ ] Module 3 — Order Blocks
//   [ ] Module 4 — Fair Value Gap
//   [ ] Module 5 — Market Maker Models
//   [ ] Module 6 — Trade Engine
//   [ ] Module 7 — Dashboard
//   [ ] Module 8 — Alerts (full)
//
// Architecture:
//   CORE     — shared constants, types, draw pool, math helpers
//   MODULE 1 — fractal Structure Engine (Internal + External)
//   MODULE 2 — Liquidity Engine (EQH/EQL, BSL/SSL, sweeps, score)
//   HOOKS    — MarketContext bridge for OB / FVG / MM
//
// Non-repaint contract:
//   • All commits require barstate.isconfirmed
//   • Fractals confirm only after right-side bars have closed
//   • Breaks use closed-bar Close or Wick only
//   • Event labels created once — never moved
//   • No request.security() / no lookahead
// ============================================================================

//@version=6
indicator(
     title            = "MM Smart Money PRO",
     shorttitle       = "MM SM PRO",
     overlay          = true,
     max_lines_count  = 500,
     max_labels_count = 500,
     max_boxes_count  = 500,
     max_bars_back    = 5000)

// ============================================================================
// INPUTS
// ============================================================================
string GRP_FRAC = "Fractal Structure"
int  intFractalLen = input.int(2, "Internal Fractal Length", minval = 1, maxval = 20, group = GRP_FRAC,
     tooltip = "Williams-style fractal half-span for INTERNAL structure. Length 2 = classic 5-bar fractal.")
int  extFractalLen = input.int(5, "External Fractal Length", minval = 2, maxval = 50, group = GRP_FRAC,
     tooltip = "Larger fractal half-span for EXTERNAL / major structure. Must be > Internal for correct separation.")
bool alternateOnly = input.bool(true, "Enforce Alternating Swings", group = GRP_FRAC,
     tooltip = "Reject consecutive same-side fractals; keep the more extreme one. Recommended for clean structure.")

string GRP_INT = "Internal Structure"
bool showInt       = input.bool(true,  "Show Internal Structure", group = GRP_INT)
bool showIntSwings = input.bool(false, "Show Internal HH/HL/LH/LL", group = GRP_INT)
bool showIntEvents = input.bool(true,  "Show Internal BOS / CHoCH", group = GRP_INT)

string GRP_EXT = "External Structure"
bool showExt       = input.bool(true, "Show External Structure", group = GRP_EXT)
bool showExtSwings = input.bool(true, "Show External HH/HL/LH/LL", group = GRP_EXT)
bool showExtEvents = input.bool(true, "Show External BOS / MSS", group = GRP_EXT)

string GRP_EVT = "Break Rules"
string breakBasis = input.string("Close", "Break Confirmation", options = ["Close", "Wick"], group = GRP_EVT,
     tooltip = "Evaluated on the CLOSED candle only.")
bool showProt     = input.bool(true, "Show Protected High / Low", group = GRP_EVT)
bool showHud      = input.bool(true, "Show Module HUD", group = GRP_EVT)

string GRP_VIS = "Visuals & Object Budget"
color bullBosCol    = input.color(color.new(#089981, 0),  "Bullish BOS", group = GRP_VIS)
color bearBosCol    = input.color(color.new(#f23645, 0),  "Bearish BOS", group = GRP_VIS)
color bullChochCol  = input.color(color.new(#00bcd4, 0),  "Bullish CHoCH", group = GRP_VIS)
color bearChochCol  = input.color(color.new(#e91e63, 0),  "Bearish CHoCH", group = GRP_VIS)
color bullMssCol    = input.color(color.new(#2962ff, 0),  "Bullish MSS", group = GRP_VIS)
color bearMssCol    = input.color(color.new(#ff6d00, 0),  "Bearish MSS", group = GRP_VIS)
color bullLineCol   = input.color(color.new(#089981, 50), "Bullish Level Line", group = GRP_VIS)
color bearLineCol   = input.color(color.new(#f23645, 50), "Bearish Level Line", group = GRP_VIS)
color protHighCol   = input.color(color.new(#f23645, 0),  "Protected High", group = GRP_VIS)
color protLowCol    = input.color(color.new(#089981, 0),  "Protected Low", group = GRP_VIS)
int  lineWInt       = input.int(1, "Internal Line Width", minval = 1, maxval = 4, group = GRP_VIS)
int  lineWExt       = input.int(2, "External Line Width", minval = 1, maxval = 4, group = GRP_VIS)
int  maxSwingStore  = input.int(30, "Max Swings Stored / Layer", minval = 8, maxval = 80, group = GRP_VIS)
int  maxActiveLines = input.int(80, "Max Active Structure Lines", minval = 20, maxval = 400, group = GRP_VIS)
int  maxActiveLabels= input.int(80, "Max Active Structure Labels", minval = 20, maxval = 400, group = GRP_VIS)

// ---- Module 2: Liquidity Engine ----
string GRP_LIQ = "Liquidity Engine"
bool showEqHigh     = input.bool(true,  "Show Equal High", group = GRP_LIQ)
bool showEqLow      = input.bool(true,  "Show Equal Low", group = GRP_LIQ)
bool showLiqPools   = input.bool(true,  "Show Liquidity Pools", group = GRP_LIQ)
bool showSweeps     = input.bool(true,  "Show Sweeps", group = GRP_LIQ)
bool showLiqLabels  = input.bool(true,  "Show Labels", group = GRP_LIQ)
bool showLiqBoxes   = input.bool(false, "Show Boxes", group = GRP_LIQ)
string liqSource    = input.string("External", "Swing Source", options = ["External", "Internal", "Both"], group = GRP_LIQ,
     tooltip = "Which Structure Engine swing arrays feed equal high/low detection.")
string tolMethod    = input.string("ATR Based", "Tolerance Method", options = ["ATR Based", "Tick Based", "Percentage Based"], group = GRP_LIQ)
float atrMultTol    = input.float(0.15, "ATR Multiplier", minval = 0.01, maxval = 5.0, step = 0.01, group = GRP_LIQ)
int  tickTol        = input.int(10, "Tick Tolerance", minval = 1, maxval = 500, group = GRP_LIQ)
float pctTol        = input.float(0.05, "Percent Tolerance", minval = 0.001, maxval = 5.0, step = 0.001, group = GRP_LIQ,
     tooltip = "Percent of price (e.g. 0.05 = 0.05%).")
float minWickPct    = input.float(30.0, "Minimum Wick %", minval = 1.0, maxval = 95.0, step = 1.0, group = GRP_LIQ,
     tooltip = "Sweep wick must be at least this % of the candle range.")
int  maxLiqStore    = input.int(25, "Maximum Stored Liquidity", minval = 5, maxval = 100, group = GRP_LIQ)
color bslCol        = input.color(color.new(#f23645, 0), "Buy Side Liquidity", group = GRP_LIQ)
color sslCol        = input.color(color.new(#089981, 0), "Sell Side Liquidity", group = GRP_LIQ)
color sweepBullCol  = input.color(color.new(#2962ff, 0), "Bullish Sweep", group = GRP_LIQ)
color sweepBearCol  = input.color(color.new(#ff6d00, 0), "Bearish Sweep", group = GRP_LIQ)
int  liqLineWidth   = input.int(1, "Liquidity Line Width", minval = 1, maxval = 4, group = GRP_LIQ)

// ============================================================================
// CORE — CONSTANTS (shared by all future modules)
// ============================================================================
const int KIND_HIGH =  1
const int KIND_LOW  = -1

const int TREND_FLAT =  0
const int TREND_BULL =  1
const int TREND_BEAR = -1

const int EVT_NONE  = 0
const int EVT_BOS   = 1
const int EVT_CHOCH = 2
const int EVT_MSS   = 3

const int CLASS_NONE = 0
const int CLASS_HH   = 1
const int CLASS_HL   = 2
const int CLASS_LH   = 3
const int CLASS_LL   = 4

const int LAYER_INTERNAL = 1
const int LAYER_EXTERNAL = 2

// ============================================================================
// CORE — REUSABLE TYPES
// ============================================================================

// Confirmed fractal pivot (immutable once created)
type Fractal
    float price
    int   barIndex
    int   kind          // KIND_HIGH / KIND_LOW
    int   strength      // fractal length used
    bool  used          // consumed by a structure layer

// Structure swing derived from a fractal
type SwingPoint
    float price
    int   barIndex
    int   kind
    int   classification
    bool  broken
    bool  isProtected
    bool  protStamped
    int   layerId
    line  levelLine
    label classLabel
    label protLabel

// One structure event (BOS / CHoCH / MSS) — immutable after emit
type StructureEvent
    int   eventType
    int   direction
    int   layerId
    float level
    int   breakBar
    int   swingBar

// Per-layer live state
type StructureState
    array<SwingPoint> swings
    int   trend
    int   layerId
    float lastHigh
    int   lastHighBar
    float lastLow
    int   lastLowBar
    float activeHigh            // current unbroken swing high (break target)
    int   activeHighBar
    float activeLow
    int   activeLowBar
    float protHigh              // trend-protected high
    int   protHighBar
    float protLow               // trend-protected low
    int   protLowBar
    int   lastEventBar
    int   lastEventType
    int   lastEventDir
    int   lastKind              // last accepted swing kind (for alternating filter)
    int   lastClassBar

// Shared draw budget — counts only; disposal is always via swing ownership
type DrawPool
    int liveLines
    int liveLabels
    int liveBoxes
    int lineBudget
    int labelBudget
    int boxBudget

// ============================================================================
// MODULE 2 — LIQUIDITY TYPES
// ============================================================================

// One liquidity pool / zone (BSL from equal highs, SSL from equal lows)
type LiquidityZone
    float price                 // representative pool price (mean of members)
    float top                   // zone ceiling
    float bottom                // zone floor
    int   kind                  // KIND_HIGH = BSL, KIND_LOW = SSL
    int   birthBar              // first member bar
    int   lastTouchBar
    int   touches               // equal-level member count
    bool  swept
    int   sweepBar
    float strength              // 0–100 visual strength
    float score                 // composite liquidity score 0–100
    bool  isStrong              // true while not swept
    bool  drawn
    bool  eqAlerted             // one-shot new EQH/EQL alert guard
    bool  sweepAlerted
    array<int>   memberBars
    array<float> memberPrices
    line  liqLine
    box   liqBox
    label liqLabel

// Liquidity engine state (owned by Module 2, mirrored into MarketContext)
type LiquidityEngine
    array<LiquidityZone> zones
    array<int> seenHighBars     // swing bars already considered for EQH
    array<int> seenLowBars      // swing bars already considered for EQL
    float nearestBSL
    float nearestSSL
    float nearestLiq
    float bestScore
    int   activeBSL
    int   activeSSL
    int   lastSweepDir          // TREND_BULL = SSL swept, TREND_BEAR = BSL swept
    int   lastSweepBar
    bool  newEqHigh
    bool  newEqLow
    bool  bullSweep             // per-bar alert wire
    bool  bearSweep             // per-bar alert wire

// Bridge object for Modules 2–5 (Liquidity, OB, FVG, MM Models)
// Populated every confirmed bar; future modules read from here only.
type MarketContext
    StructureState internal
    StructureState external
    StructureEvent lastIntEvent
    StructureEvent lastExtEvent
    float atr
    int   bias                  // external trend as institutional bias
    int   confirmedBar          // bar_index of last commit (na if none)
    LiquidityEngine liquidity   // Module 2 mirror

// ============================================================================
// CORE — FACTORIES
// ============================================================================
newStructureState(int layerId) =>
    StructureState.new(
         array.new<SwingPoint>(),
         TREND_FLAT,
         layerId,
         na, na, na, na,
         na, na, na, na,
         na, na, na, na,
         na, EVT_NONE, TREND_FLAT,
         0, na)

newDrawPool(int lineBudget, int labelBudget, int boxBudget) =>
    DrawPool.new(0, 0, 0, lineBudget, labelBudget, boxBudget)

newEmptyEvent() =>
    StructureEvent.new(EVT_NONE, TREND_FLAT, 0, na, na, na)

newLiquidityEngine() =>
    LiquidityEngine.new(
         array.new<LiquidityZone>(),
         array.new<int>(),
         array.new<int>(),
         na, na, na, na,
         0, 0,
         TREND_FLAT, na,
         false, false, false, false)

// ============================================================================
// CORE — DRAW POOL (object management)
// ----------------------------------------------------------------------------
// Ownership model:
//   • Every line/label belongs to a SwingPoint (or is an event stamp).
//   • Event stamps are never moved; they may be retired only when the global
//     label budget is exceeded (oldest first) via f_retireOldestLabel_().
//   • Swing drawings are deleted only when their SwingPoint is trimmed.
//   • Never call line/label methods after delete — refs are nulled immediately.
// ============================================================================
var DrawPool pool = newDrawPool(maxActiveLines, maxActiveLabels, 200)
var array<label> eventStamps = array.new<label>()

f_deleteLine(line ln) =>
    if not na(ln)
        line.delete(ln)
        pool.liveLines := math.max(0, pool.liveLines - 1)

f_deleteLabel(label lb) =>
    if not na(lb)
        label.delete(lb)
        pool.liveLabels := math.max(0, pool.liveLabels - 1)

f_deleteBox(box bx) =>
    if not na(bx)
        box.delete(bx)
        pool.liveBoxes := math.max(0, pool.liveBoxes - 1)

f_disposeSwingDraw(SwingPoint s) =>
    f_deleteLine(s.levelLine)
    f_deleteLabel(s.classLabel)
    f_deleteLabel(s.protLabel)
    s.levelLine := na
    s.classLabel := na
    s.protLabel := na

f_newLevelLine(int x1, float y, int x2, color col, int w) =>
    line ln = line.new(x1, y, x2, y, xloc = xloc.bar_index, color = col, width = w)
    pool.liveLines := pool.liveLines + 1
    ln

f_newStampLabel(int x, float y, string txt, color col, string style, string sz, bool isEvent) =>
    // Retire oldest event stamps first if over label budget
    while isEvent and array.size(eventStamps) > 0 and pool.liveLabels >= pool.labelBudget
        label old = array.shift(eventStamps)
        f_deleteLabel(old)
    label lb = label.new(
         x, y, txt,
         xloc = xloc.bar_index,
         yloc = yloc.price,
         color = color.new(col, 100),
         textcolor = col,
         style = style,
         size = sz)
    pool.liveLabels := pool.liveLabels + 1
    if isEvent
        array.push(eventStamps, lb)
    lb

// ============================================================================
// CORE — MATH / SERIES HELPERS
// ============================================================================
f_bullBreak(float level) =>
    breakBasis == "Close" ? close > level : high > level

f_bearBreak(float level) =>
    breakBasis == "Close" ? close < level : low < level

f_className(int c) =>
    switch c
        CLASS_HH => "HH"
        CLASS_HL => "HL"
        CLASS_LH => "LH"
        CLASS_LL => "LL"
        => ""

f_eventName(int e) =>
    switch e
        EVT_BOS   => "BOS"
        EVT_CHOCH => "CHoCH"
        EVT_MSS   => "MSS"
        => ""

f_eventColor(int e, int dir) =>
    dir == TREND_BULL ? (e == EVT_BOS ? bullBosCol : e == EVT_CHOCH ? bullChochCol : bullMssCol) : (e == EVT_BOS ? bearBosCol : e == EVT_CHOCH ? bearChochCol : bearMssCol)

f_trendName(int t) =>
    t == TREND_BULL ? "Bullish" : t == TREND_BEAR ? "Bearish" : "Flat"

f_atr = ta.atr(14)

// ============================================================================
// CORE — FRACTAL ENGINE (non-repainting)
// ----------------------------------------------------------------------------
// A fractal high of length L is confirmed on the current CLOSED bar when the
// bar at offset L has a high strictly greater than the L bars to its left and
// the L bars to its right. Right-side bars are already closed → no lookahead.
// Same logic inverted for fractal lows.
// ============================================================================
f_fractalHigh(int len) =>
    bool ok = bar_index >= 2 * len
    float center = high[len]
    if ok
        for i = 1 to len
            if high[len - i] >= center or high[len + i] >= center
                ok := false
                break
    ok ? center : float(na)

f_fractalLow(int len) =>
    bool ok = bar_index >= 2 * len
    float center = low[len]
    if ok
        for i = 1 to len
            if low[len - i] <= center or low[len + i] <= center
                ok := false
                break
    ok ? center : float(na)

f_makeFractal(float price, int len, int kind) =>
    Fractal.new(price, bar_index - len, kind, len, false)

// ============================================================================
// MODULE 1 — STRUCTURE HELPERS
// ============================================================================
f_trimSwings(StructureState st) =>
    while array.size(st.swings) > maxSwingStore
        SwingPoint old = array.shift(st.swings)
        f_disposeSwingDraw(old)
    // Soft line budget: if still over, dispose oldest broken swings' lines first
    if pool.liveLines > pool.lineBudget and array.size(st.swings) > 0
        for i = 0 to array.size(st.swings) - 1
            if pool.liveLines <= pool.lineBudget
                break
            SwingPoint s = array.get(st.swings, i)
            if s.broken and not na(s.levelLine)
                f_deleteLine(s.levelLine)
                s.levelLine := na
                array.set(st.swings, i, s)

f_classify(StructureState st, float price, int kind) =>
    int cls = CLASS_NONE
    if kind == KIND_HIGH and not na(st.lastHigh)
        cls := price > st.lastHigh ? CLASS_HH : CLASS_LH
    else if kind == KIND_LOW and not na(st.lastLow)
        cls := price > st.lastLow ? CLASS_HL : CLASS_LL
    cls

f_findSwingIndex(StructureState st, int barIdx, int kind) =>
    int found = -1
    int sz = array.size(st.swings)
    if sz > 0
        for i = sz - 1 to 0
            SwingPoint s = array.get(st.swings, i)
            if s.barIndex == barIdx and s.kind == kind
                found := i
                break
    found

f_markBroken(StructureState st, int kind) =>
    int sz = array.size(st.swings)
    if sz > 0
        for i = 0 to sz - 1
            SwingPoint s = array.get(st.swings, i)
            if s.kind == kind and not s.broken
                bool hit = kind == KIND_HIGH ? f_bullBreak(s.price) : f_bearBreak(s.price)
                if hit
                    s.broken := true
                    s.isProtected := false
                    if not na(s.levelLine)
                        line.set_x2(s.levelLine, bar_index)
                    array.set(st.swings, i, s)

f_extendLines(StructureState st) =>
    int sz = array.size(st.swings)
    if sz > 0
        for i = 0 to sz - 1
            SwingPoint s = array.get(st.swings, i)
            if not s.broken and not na(s.levelLine)
                line.set_x2(s.levelLine, bar_index)

// ----------------------------------------------------------------------------
// Trend-protection logic for Protected High / Protected Low
// ----------------------------------------------------------------------------
// Bullish trend:
//   • Structure protects demand → Protected Low = last unbroken swing low
//     that supports the bullish bias (prefer last HL after a bullish event).
//   • Updates when a newer HL is accepted; cleared when that low is broken.
// Bearish trend:
//   • Structure protects supply → Protected High = last unbroken swing high
//     that supports the bearish bias (prefer last LH after a bearish event).
//   • Updates when a newer LH is accepted; cleared when that high is broken.
// Stamps are one-shot on the swing bar — never relocated.
// ----------------------------------------------------------------------------
f_applyTrendProtection(StructureState st, bool allowDraw, bool showLayer) =>
    // Trend protection:
    //   Bullish → protect demand (PL). Prefer newest unbroken HL; fallback newest low.
    //   Bearish → protect supply (PH). Prefer newest unbroken LH; fallback newest high.
    float candPH = na
    int   candPHBar = na
    float candPL = na
    int   candPLBar = na
    int sz = array.size(st.swings)

    if st.trend == TREND_BULL and sz > 0
        // Pass 1: newest HL
        for i = sz - 1 to 0
            SwingPoint s = array.get(st.swings, i)
            if s.kind == KIND_LOW and not s.broken and s.classification == CLASS_HL
                candPL := s.price
                candPLBar := s.barIndex
                break
        // Pass 2: fallback newest unbroken low
        if na(candPL)
            for i = sz - 1 to 0
                SwingPoint s = array.get(st.swings, i)
                if s.kind == KIND_LOW and not s.broken
                    candPL := s.price
                    candPLBar := s.barIndex
                    break

    if st.trend == TREND_BEAR and sz > 0
        for i = sz - 1 to 0
            SwingPoint s = array.get(st.swings, i)
            if s.kind == KIND_HIGH and not s.broken and s.classification == CLASS_LH
                candPH := s.price
                candPHBar := s.barIndex
                break
        if na(candPH)
            for i = sz - 1 to 0
                SwingPoint s = array.get(st.swings, i)
                if s.kind == KIND_HIGH and not s.broken
                    candPH := s.price
                    candPHBar := s.barIndex
                    break

    st.protHigh    := candPH
    st.protHighBar := candPHBar
    st.protLow     := candPL
    st.protLowBar  := candPLBar

    if sz > 0
        for i = 0 to sz - 1
            SwingPoint s = array.get(st.swings, i)
            bool prot = false
            if not s.broken
                if s.kind == KIND_HIGH and not na(st.protHighBar) and s.barIndex == st.protHighBar
                    prot := true
                if s.kind == KIND_LOW and not na(st.protLowBar) and s.barIndex == st.protLowBar
                    prot := true
            s.isProtected := prot
            if allowDraw and showLayer and showProt and prot and not s.protStamped
                s.protLabel := f_newStampLabel(
                     s.barIndex, s.price,
                     s.kind == KIND_HIGH ? "PH" : "PL",
                     s.kind == KIND_HIGH ? protHighCol : protLowCol,
                     s.kind == KIND_HIGH ? label.style_label_down : label.style_label_up,
                     size.tiny, false)
                s.protStamped := true
            array.set(st.swings, i, s)

// ============================================================================
// MODULE 1 — REGISTER FRACTAL INTO A STRUCTURE LAYER
// ============================================================================
f_acceptSwing(StructureState st, Fractal fr, bool showLayer, bool showClass, color lineCol, int lineW) =>
    bool accepted = true

    // Alternating swing filter (clean structure)
    if alternateOnly and st.lastKind != 0
        if fr.kind == st.lastKind
            // Same side: keep more extreme, replace previous active tip
            int idx = f_findSwingIndex(st, st.lastKind == KIND_HIGH ? st.lastHighBar : st.lastLowBar, fr.kind)
            if fr.kind == KIND_HIGH
                if not na(st.lastHigh) and fr.price <= st.lastHigh
                    accepted := false
                else if idx >= 0
                    SwingPoint prev = array.get(st.swings, idx)
                    prev.broken := true
                    if not na(prev.levelLine)
                        line.set_x2(prev.levelLine, fr.barIndex)
                    array.set(st.swings, idx, prev)
            else
                if not na(st.lastLow) and fr.price >= st.lastLow
                    accepted := false
                else if idx >= 0
                    SwingPoint prev = array.get(st.swings, idx)
                    prev.broken := true
                    if not na(prev.levelLine)
                        line.set_x2(prev.levelLine, fr.barIndex)
                    array.set(st.swings, idx, prev)

    if accepted
        int cls = f_classify(st, fr.price, fr.kind)
        line ln = na
        label lb = na

        if showLayer
            ln := f_newLevelLine(fr.barIndex, fr.price, bar_index, lineCol, lineW)

        if showLayer and showClass and cls != CLASS_NONE
            if na(st.lastClassBar) or st.lastClassBar != fr.barIndex
                lb := f_newStampLabel(
                     fr.barIndex, fr.price, f_className(cls), lineCol,
                     fr.kind == KIND_HIGH ? label.style_label_down : label.style_label_up,
                     size.tiny, false)
                st.lastClassBar := fr.barIndex

        SwingPoint sp = SwingPoint.new(
             fr.price, fr.barIndex, fr.kind, cls,
             false, false, false, st.layerId,
             ln, lb, na)
        array.push(st.swings, sp)
        f_trimSwings(st)

        if fr.kind == KIND_HIGH
            st.lastHigh     := fr.price
            st.lastHighBar  := fr.barIndex
            st.activeHigh   := fr.price
            st.activeHighBar:= fr.barIndex
        else
            st.lastLow      := fr.price
            st.lastLowBar   := fr.barIndex
            st.activeLow    := fr.price
            st.activeLowBar := fr.barIndex

        st.lastKind := fr.kind

        // Seed bias from first classified pair
        if st.trend == TREND_FLAT
            if cls == CLASS_HH or cls == CLASS_HL
                st.trend := TREND_BULL
            else if cls == CLASS_LL or cls == CLASS_LH
                st.trend := TREND_BEAR

        f_applyTrendProtection(st, true, showLayer)
        fr.used := true

    accepted

// ============================================================================
// MODULE 1 — BREAK ENGINE (BOS / CHoCH / MSS)
// ----------------------------------------------------------------------------
// Internal layer opposing break → CHoCH
// External layer opposing break → MSS
// Same-direction break          → BOS
// ============================================================================
f_detectBreaks(StructureState st, bool showLayer, bool showEvents) =>
    StructureEvent ev = newEmptyEvent()

    if barstate.isconfirmed
        bool didBull = not na(st.activeHigh) and f_bullBreak(st.activeHigh)
        bool didBear = not na(st.activeLow) and f_bearBreak(st.activeLow)

        if didBull and didBear
            if close >= open
                didBear := false
            else
                didBull := false

        if didBull or didBear
            int dir = didBull ? TREND_BULL : TREND_BEAR
            int evt = EVT_NONE
            float lvl = didBull ? st.activeHigh : st.activeLow
            int swingBar = didBull ? st.activeHighBar : st.activeLowBar

            if st.trend == TREND_FLAT
                evt := EVT_BOS
            else if didBull
                evt := st.trend == TREND_BULL ? EVT_BOS : (st.layerId == LAYER_EXTERNAL ? EVT_MSS : EVT_CHOCH)
            else
                evt := st.trend == TREND_BEAR ? EVT_BOS : (st.layerId == LAYER_EXTERNAL ? EVT_MSS : EVT_CHOCH)

            if na(st.lastEventBar) or st.lastEventBar != bar_index
                st.lastEventBar  := bar_index
                st.lastEventType := evt
                st.lastEventDir  := dir
                st.trend         := dir

                if didBull
                    f_markBroken(st, KIND_HIGH)
                    st.activeHigh    := na
                    st.activeHighBar := na
                else
                    f_markBroken(st, KIND_LOW)
                    st.activeLow    := na
                    st.activeLowBar := na

                // After BOS, the opposite swing that held the move becomes protected
                f_applyTrendProtection(st, true, showLayer)

                bool drawIt = showLayer and showEvents and evt != EVT_NONE
                if drawIt
                    string prefix = st.layerId == LAYER_INTERNAL ? "i" : ""
                    f_newStampLabel(
                         bar_index,
                         dir == TREND_BULL ? low : high,
                         prefix + f_eventName(evt),
                         f_eventColor(evt, dir),
                         dir == TREND_BULL ? label.style_label_up : label.style_label_down,
                         size.small, true)

                ev := StructureEvent.new(evt, dir, st.layerId, lvl, bar_index, swingBar)

        if showLayer
            f_extendLines(st)

    ev


// ============================================================================
// MODULE 2 — LIQUIDITY ENGINE
// ----------------------------------------------------------------------------
// Consumes Structure Engine swing arrays (Internal / External / Both).
// Equal Highs → Buy Side Liquidity (BSL)
// Equal Lows  → Sell Side Liquidity (SSL)
// Sweeps confirm only on closed candles with wick-through + close-back + wick %.
// ============================================================================

// ---- Calculations ----
f_liqTolerance(float refPrice, float atrVal) =>
    float tol = atrVal * atrMultTol
    if tolMethod == "Tick Based"
        tol := syminfo.mintick * tickTol
    else if tolMethod == "Percentage Based"
        tol := math.abs(refPrice) * pctTol / 100.0
    math.max(tol, syminfo.mintick)

f_liqWickPct(bool isHighSweep) =>
    float rng = high - low
    float pct = 0.0
    if rng > 0
        float wick = isHighSweep ? (high - math.max(open, close)) : (math.min(open, close) - low)
        pct := wick / rng * 100.0
    pct

f_liqCalcScore(LiquidityZone z) =>
    int age = math.max(0, bar_index - z.birthBar)
    float touchPts = math.min(40.0, z.touches * 8.0)
    float agePts = math.min(20.0, age * 0.4)
    float activePts = z.swept ? 0.0 : 30.0
    float clusterPts = math.min(10.0, math.max(0, z.touches - 1) * 5.0)
    float raw = touchPts + agePts + activePts + clusterPts
    z.strength := math.min(100.0, touchPts + agePts + clusterPts + (z.swept ? 0.0 : 20.0))
    z.score := math.min(100.0, raw)
    z.isStrong := not z.swept
    z

f_liqBarSeen(array<int> arr, int barIdx) =>
    bool seen = false
    int sz = array.size(arr)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(arr, i) == barIdx
                seen := true
                break
    seen

f_liqMarkSeen(array<int> arr, int barIdx) =>
    if not f_liqBarSeen(arr, barIdx)
        array.push(arr, barIdx)
        while array.size(arr) > maxLiqStore * 4
            array.shift(arr)

// ---- Object management / drawing ----
f_liqDisposeZone(LiquidityZone z) =>
    f_deleteLine(z.liqLine)
    f_deleteLabel(z.liqLabel)
    f_deleteBox(z.liqBox)
    z.liqLine := na
    z.liqLabel := na
    z.liqBox := na
    z.drawn := false

f_liqTrim(LiquidityEngine eng) =>
    while array.size(eng.zones) > maxLiqStore
        LiquidityZone old = array.shift(eng.zones)
        f_liqDisposeZone(old)

f_liqZoneText(LiquidityZone z) =>
    // Compact zone tag: side · Strong/Weak · score% · touches · age
    // Example: "BSL·S 92%×4 a18"
    string side = z.kind == KIND_HIGH ? "BSL" : "SSL"
    string sw = z.isStrong ? "S" : "W"
    int age = math.max(0, bar_index - z.birthBar)
    side + "·" + sw + " " + str.tostring(math.round(z.score)) + "%×" + str.tostring(z.touches) + " a" + str.tostring(age)

f_liqEnsureDraw(LiquidityZone z) =>
    bool showSide = z.kind == KIND_HIGH ? (showEqHigh or showLiqPools) : (showEqLow or showLiqPools)
    if not showSide or z.touches < 2
        z
    else
        color col = z.kind == KIND_HIGH ? bslCol : sslCol
        if z.swept
            col := color.new(col, 70)

        // Line — create once, extend right while active
        if showLiqPools or showEqHigh or showEqLow
            if na(z.liqLine)
                z.liqLine := f_newLevelLine(z.birthBar, z.price, bar_index, col, liqLineWidth)
                if z.swept
                    line.set_style(z.liqLine, line.style_dotted)
            else
                line.set_x2(z.liqLine, z.swept and not na(z.sweepBar) ? z.sweepBar : bar_index)
                line.set_color(z.liqLine, col)
                line.set_y1(z.liqLine, z.price)
                line.set_y2(z.liqLine, z.price)

        // Optional box around pool band (pad flat equals by 1 tick for visibility)
        if showLiqBoxes
            float boxTop = z.top
            float boxBot = z.bottom
            if boxTop - boxBot < syminfo.mintick
                boxTop := z.price + syminfo.mintick
                boxBot := z.price - syminfo.mintick
            if na(z.liqBox)
                if pool.liveBoxes < pool.boxBudget
                    z.liqBox := box.new(z.birthBar, boxTop, bar_index, boxBot, xloc = xloc.bar_index, border_color = col, bgcolor = color.new(col, 88), border_width = 1)
                    pool.liveBoxes := pool.liveBoxes + 1
            else
                box.set_right(z.liqBox, z.swept and not na(z.sweepBar) ? z.sweepBar : bar_index)
                box.set_top(z.liqBox, boxTop)
                box.set_bottom(z.liqBox, boxBot)
                box.set_border_color(z.liqBox, col)
                box.set_bgcolor(z.liqBox, color.new(col, 88))

        // Label — one stamp at last touch; text may update in place for score only
        // (position stays on lastTouchBar — never relocated to a new bar)
        if showLiqLabels
            string txt = f_liqZoneText(z)
            if na(z.liqLabel)
                z.liqLabel := f_newStampLabel(
                     z.lastTouchBar, z.price, txt, col,
                     z.kind == KIND_HIGH ? label.style_label_down : label.style_label_up,
                     size.tiny, false)
            else
                label.set_text(z.liqLabel, txt)
                label.set_color(z.liqLabel, color.new(col, 100))
                label.set_textcolor(z.liqLabel, col)

        z.drawn := true
        z

// ---- Detection: find / merge pools ----
f_liqFindPool(LiquidityEngine eng, float price, int kind, float tol) =>
    int found = -1
    int sz = array.size(eng.zones)
    if sz > 0
        for i = sz - 1 to 0
            LiquidityZone z = array.get(eng.zones, i)
            if z.kind == kind and not z.swept and math.abs(z.price - price) <= tol
                found := i
                break
    found

f_liqCreateZone(LiquidityEngine eng, float p1, int b1, float p2, int b2, int kind) =>
    float top = math.max(p1, p2)
    float bot = math.min(p1, p2)
    float mid = (p1 + p2) * 0.5
    int birth = math.min(b1, b2)
    int lastT = math.max(b1, b2)
    array<int> mb = array.new<int>()
    array<float> mp = array.new<float>()
    array.push(mb, b1)
    array.push(mb, b2)
    array.push(mp, p1)
    array.push(mp, p2)
    LiquidityZone z = LiquidityZone.new(
         mid, top, bot, kind, birth, lastT, 2,
         false, na, 0.0, 0.0, true, false, false, false,
         mb, mp, na, na, na)
    z := f_liqCalcScore(z)
    z := f_liqEnsureDraw(z)
    array.push(eng.zones, z)
    f_liqTrim(eng)
    if kind == KIND_HIGH
        eng.newEqHigh := true
    else
        eng.newEqLow := true

f_liqMergeInto(LiquidityEngine eng, int zi, float price, int barIdx) =>
    LiquidityZone z = array.get(eng.zones, zi)
    // Avoid duplicate member bars
    bool dup = f_liqBarSeen(z.memberBars, barIdx)
    if not dup
        array.push(z.memberBars, barIdx)
        array.push(z.memberPrices, price)
        z.touches := array.size(z.memberBars)
        z.lastTouchBar := barIdx
        z.top := math.max(z.top, price)
        z.bottom := math.min(z.bottom, price)
        // Recompute mean price
        float sum = 0.0
        for i = 0 to array.size(z.memberPrices) - 1
            sum := sum + array.get(z.memberPrices, i)
        z.price := sum / array.size(z.memberPrices)
        z := f_liqCalcScore(z)
        z := f_liqEnsureDraw(z)
        array.set(eng.zones, zi, z)
        if z.kind == KIND_HIGH
            eng.newEqHigh := true
        else
            eng.newEqLow := true
        if not z.eqAlerted and z.touches >= 2
            z.eqAlerted := true
            array.set(eng.zones, zi, z)

f_liqPartnerSwing(StructureState st, SwingPoint src, float tol) =>
    float pOut = float(na)
    int bOut = int(na)
    int sz = array.size(st.swings)
    if sz > 0
        for i = sz - 1 to 0
            SwingPoint s = array.get(st.swings, i)
            if s.kind == src.kind and s.barIndex != src.barIndex
                if math.abs(s.price - src.price) <= tol
                    pOut := s.price
                    bOut := s.barIndex
                    break
    [pOut, bOut]

f_liqIngestSwing(LiquidityEngine eng, StructureState st, SwingPoint sp, float atrVal) =>
    float tol = f_liqTolerance(sp.price, atrVal)
    array<int> seen = sp.kind == KIND_HIGH ? eng.seenHighBars : eng.seenLowBars
    if not f_liqBarSeen(seen, sp.barIndex)
        f_liqMarkSeen(seen, sp.barIndex)
        int zi = f_liqFindPool(eng, sp.price, sp.kind, tol)
        if zi >= 0
            f_liqMergeInto(eng, zi, sp.price, sp.barIndex)
        else
            [pp, pb] = f_liqPartnerSwing(st, sp, tol)
            if not na(pp) and not na(pb)
                // Also try merge if partner already in a pool
                int zj = f_liqFindPool(eng, pp, sp.kind, tol)
                if zj >= 0
                    f_liqMergeInto(eng, zj, sp.price, sp.barIndex)
                else
                    f_liqCreateZone(eng, sp.price, sp.barIndex, pp, pb, sp.kind)

f_liqIngestState(LiquidityEngine eng, StructureState st, float atrVal) =>
    int sz = array.size(st.swings)
    if sz > 0
        // Newest first — prefer fresh structure tips
        for i = sz - 1 to 0
            SwingPoint sp = array.get(st.swings, i)
            f_liqIngestSwing(eng, st, sp, atrVal)

// ---- Sweep detection (confirmed bar only) ----
f_liqDetectSweeps(LiquidityEngine eng) =>
    eng.bullSweep := false
    eng.bearSweep := false
    int sz = array.size(eng.zones)
    if sz > 0
        float rng = high - low
        for i = 0 to sz - 1
            LiquidityZone z = array.get(eng.zones, i)
            if not z.swept and z.touches >= 2 and rng > 0
                if z.kind == KIND_HIGH
                    // Bearish sweep: wick through BSL, close back below zone
                    bool wickThru = high > z.top
                    bool closeBack = close < z.bottom
                    bool wickOk = f_liqWickPct(true) >= minWickPct
                    if wickThru and closeBack and wickOk
                        z.swept := true
                        z.sweepBar := bar_index
                        z.isStrong := false
                        z := f_liqCalcScore(z)
                        z := f_liqEnsureDraw(z)
                        if showSweeps
                            f_newStampLabel(bar_index, high, "Sweep", sweepBearCol, label.style_label_down, size.small, true)
                        eng.bearSweep := true
                        eng.lastSweepDir := TREND_BEAR
                        eng.lastSweepBar := bar_index
                        array.set(eng.zones, i, z)
                else
                    // Bullish sweep: wick through SSL, close back above zone
                    bool wickThru = low < z.bottom
                    bool closeBack = close > z.top
                    bool wickOk = f_liqWickPct(false) >= minWickPct
                    if wickThru and closeBack and wickOk
                        z.swept := true
                        z.sweepBar := bar_index
                        z.isStrong := false
                        z := f_liqCalcScore(z)
                        z := f_liqEnsureDraw(z)
                        if showSweeps
                            f_newStampLabel(bar_index, low, "Sweep", sweepBullCol, label.style_label_up, size.small, true)
                        eng.bullSweep := true
                        eng.lastSweepDir := TREND_BULL
                        eng.lastSweepBar := bar_index
                        array.set(eng.zones, i, z)

// ---- Book-keeping / nearest liquidity ----
f_liqRefreshStats(LiquidityEngine eng) =>
    eng.nearestBSL := na
    eng.nearestSSL := na
    eng.nearestLiq := na
    eng.bestScore := na
    eng.activeBSL := 0
    eng.activeSSL := 0
    float best = -1.0
    float nearDist = 1e100
    float nearPrice = na
    int sz = array.size(eng.zones)
    if sz > 0
        for i = 0 to sz - 1
            LiquidityZone z = array.get(eng.zones, i)
            z := f_liqCalcScore(z)
            // Extend active drawings each bar
            if not z.swept
                z := f_liqEnsureDraw(z)
            array.set(eng.zones, i, z)
            if not z.swept and z.touches >= 2
                if z.kind == KIND_HIGH
                    eng.activeBSL := eng.activeBSL + 1
                    if z.price >= close and (na(eng.nearestBSL) or z.price < eng.nearestBSL)
                        eng.nearestBSL := z.price
                else
                    eng.activeSSL := eng.activeSSL + 1
                    if z.price <= close and (na(eng.nearestSSL) or z.price > eng.nearestSSL)
                        eng.nearestSSL := z.price
                if z.score > best
                    best := z.score
                float d = math.abs(z.price - close)
                if d < nearDist
                    nearDist := d
                    nearPrice := z.price
    eng.bestScore := best >= 0 ? best : float(na)
    eng.nearestLiq := nearPrice

// ---- Module 2 entrypoint ----
f_liqOnConfirmed(LiquidityEngine eng, StructureState stInt, StructureState stExt, float atrVal) =>
    eng.newEqHigh := false
    eng.newEqLow := false
    eng.bullSweep := false
    eng.bearSweep := false

    if liqSource == "External" or liqSource == "Both"
        f_liqIngestState(eng, stExt, atrVal)
    if liqSource == "Internal" or liqSource == "Both"
        f_liqIngestState(eng, stInt, atrVal)

    f_liqDetectSweeps(eng)
    f_liqRefreshStats(eng)

// ============================================================================
// MODULE STATE
// ============================================================================
var StructureState stInternal = newStructureState(LAYER_INTERNAL)
var StructureState stExternal = newStructureState(LAYER_EXTERNAL)

var LiquidityEngine liqEng = newLiquidityEngine()

var MarketContext ctx = MarketContext.new(
     stInternal, stExternal,
     newEmptyEvent(), newEmptyEvent(),
     na, TREND_FLAT, na,
     liqEng)

// Guard: external fractal length must exceed internal for true separation
int effExtLen = math.max(extFractalLen, intFractalLen + 1)

// Per-bar event wires (series — safe for alerts / future modules)
int iEvt = EVT_NONE
int iDir = TREND_FLAT
int eEvt = EVT_NONE
int eDir = TREND_FLAT

// Module 2 alert wires — reset every bar (prevents sticky realtime alerts)
bool aBullSweep = false
bool aBearSweep = false
bool aNewEqHigh = false
bool aNewEqLow  = false

// ============================================================================
// MAIN — confirmed bars only
// ============================================================================
if barstate.isconfirmed
    // Keep pool budgets in sync with inputs
    pool.lineBudget  := maxActiveLines
    pool.labelBudget := maxActiveLabels
    pool.boxBudget   := 200

    // --- Fractal detection (right-side closed → non-repaint) ---
    float iH = f_fractalHigh(intFractalLen)
    float iL = f_fractalLow(intFractalLen)
    float eH = f_fractalHigh(effExtLen)
    float eL = f_fractalLow(effExtLen)

    // --- Internal layer (micro structure) ---
    if not na(iH)
        Fractal fr = f_makeFractal(iH, intFractalLen, KIND_HIGH)
        f_acceptSwing(stInternal, fr, showInt, showIntSwings, bearLineCol, lineWInt)
    if not na(iL)
        Fractal fr = f_makeFractal(iL, intFractalLen, KIND_LOW)
        f_acceptSwing(stInternal, fr, showInt, showIntSwings, bullLineCol, lineWInt)

    // --- External layer (macro structure) — independent larger fractal stream ---
    if not na(eH)
        Fractal fr = f_makeFractal(eH, effExtLen, KIND_HIGH)
        f_acceptSwing(stExternal, fr, showExt, showExtSwings, bearLineCol, lineWExt)
    if not na(eL)
        Fractal fr = f_makeFractal(eL, effExtLen, KIND_LOW)
        f_acceptSwing(stExternal, fr, showExt, showExtSwings, bullLineCol, lineWExt)

    // --- Breaks: internal first (early warning), then external (major) ---
    StructureEvent evI = f_detectBreaks(stInternal, showInt, showIntEvents)
    StructureEvent evE = f_detectBreaks(stExternal, showExt, showExtEvents)

    iEvt := evI.eventType
    iDir := evI.direction
    eEvt := evE.eventType
    eDir := evE.direction

    // --- MarketContext bridge (Modules 2–5 read this; never raw pivots) ---
    ctx.internal      := stInternal
    ctx.external      := stExternal
    ctx.lastIntEvent  := evI
    ctx.lastExtEvent  := evE
    ctx.atr           := f_atr
    ctx.bias          := stExternal.trend
    ctx.confirmedBar  := bar_index

    // --- Module 2: Liquidity Engine (uses Structure swings via ctx states) ---
    f_liqOnConfirmed(liqEng, stInternal, stExternal, f_atr)
    ctx.liquidity := liqEng
    aBullSweep := liqEng.bullSweep
    aBearSweep := liqEng.bearSweep
    aNewEqHigh := liqEng.newEqHigh
    aNewEqLow  := liqEng.newEqLow

// ============================================================================
// FUTURE MODULE HOOKS (placeholders — compile-safe stubs)
// ----------------------------------------------------------------------------
// Module 3 OrderBlock → consumes displacement after ctx last events + ATR + sweeps
// Module 4 FVG        → consumes impulse legs between structure swings + ATR
// Module 5 MM Models  → consumes EQH/EQL sweeps + MSS + OB + premium/discount
// These modules must only commit on barstate.isconfirmed using ctx.confirmedBar.
// ============================================================================
f_ctxBias() => ctx.bias
f_ctxAtr() => ctx.atr
f_ctxInternalTrend() => ctx.internal.trend
f_ctxExternalTrend() => ctx.external.trend
f_ctxProtHigh() => ctx.external.protHigh
f_ctxProtLow() => ctx.external.protLow
f_ctxActiveExtHigh() => ctx.external.activeHigh
f_ctxActiveExtLow() => ctx.external.activeLow
f_ctxNearestBSL() => ctx.liquidity.nearestBSL
f_ctxNearestSSL() => ctx.liquidity.nearestSSL
f_ctxLiqScore() => ctx.liquidity.bestScore
f_ctxNearestLiq() => ctx.liquidity.nearestLiq

// ============================================================================
// DATA WINDOW — exports for Dashboard (Module 7) + ctx accessors
// ============================================================================
plot(f_ctxInternalTrend(), title = "Internal Trend", display = display.data_window)
plot(f_ctxExternalTrend(), title = "External Trend", display = display.data_window)
plot(f_ctxBias(), title = "Bias", display = display.data_window)
plot(f_ctxProtHigh(), title = "Protected High", display = display.data_window)
plot(f_ctxProtLow(), title = "Protected Low", display = display.data_window)
plot(f_ctxActiveExtHigh(), title = "Ext Active High", display = display.data_window)
plot(f_ctxActiveExtLow(), title = "Ext Active Low", display = display.data_window)
plot(ctx.internal.activeHigh, title = "Int Active High", display = display.data_window)
plot(ctx.internal.activeLow, title = "Int Active Low", display = display.data_window)
plot(iEvt, title = "Internal Event", display = display.data_window)
plot(eEvt, title = "External Event", display = display.data_window)
plot(f_ctxAtr(), title = "ATR", display = display.data_window)
plot(f_ctxNearestBSL(), title = "Nearest BSL", display = display.data_window)
plot(f_ctxNearestSSL(), title = "Nearest SSL", display = display.data_window)
plot(f_ctxNearestLiq(), title = "Nearest Liquidity", display = display.data_window)
plot(f_ctxLiqScore(), title = "Liquidity Score", display = display.data_window)
plot(liqEng.activeBSL, title = "Active BSL Count", display = display.data_window)
plot(liqEng.activeSSL, title = "Active SSL Count", display = display.data_window)

// ============================================================================
// ALERTS — structure foundation (Module 8)
// ============================================================================
alertcondition(iEvt == EVT_BOS and iDir == TREND_BULL, "Internal Bullish BOS", "MM SM PRO: Internal Bullish BOS")
alertcondition(iEvt == EVT_BOS and iDir == TREND_BEAR, "Internal Bearish BOS", "MM SM PRO: Internal Bearish BOS")
alertcondition(iEvt == EVT_CHOCH and iDir == TREND_BULL, "Internal Bullish CHoCH", "MM SM PRO: Internal Bullish CHoCH")
alertcondition(iEvt == EVT_CHOCH and iDir == TREND_BEAR, "Internal Bearish CHoCH", "MM SM PRO: Internal Bearish CHoCH")
alertcondition(eEvt == EVT_BOS and eDir == TREND_BULL, "External Bullish BOS", "MM SM PRO: External Bullish BOS")
alertcondition(eEvt == EVT_BOS and eDir == TREND_BEAR, "External Bearish BOS", "MM SM PRO: External Bearish BOS")
alertcondition(eEvt == EVT_MSS and eDir == TREND_BULL, "Bullish MSS", "MM SM PRO: Bullish MSS")
alertcondition(eEvt == EVT_MSS and eDir == TREND_BEAR, "Bearish MSS", "MM SM PRO: Bearish MSS")
alertcondition(aBullSweep, "Bullish Liquidity Sweep", "MM SM PRO: Bullish Liquidity Sweep (SSL)")
alertcondition(aBearSweep, "Bearish Liquidity Sweep", "MM SM PRO: Bearish Liquidity Sweep (BSL)")
alertcondition(aNewEqHigh, "New Equal High", "MM SM PRO: New Equal High / BSL")
alertcondition(aNewEqLow, "New Equal Low", "MM SM PRO: New Equal Low / SSL")

// ============================================================================
// HUD — Structure + Liquidity
// ============================================================================
var table hud = table.new(position.top_right, 2, 12, border_width = 1)

if showHud and barstate.isconfirmed and barstate.islast
    color bg = color.new(#1e222d, 10)
    table.cell(hud, 0, 0, "MM Smart Money PRO", text_color = color.white, bgcolor = color.new(#1e222d, 0), text_halign = text.align_center)
    table.merge_cells(hud, 0, 0, 1, 0)
    table.cell(hud, 0, 1, "Modules", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 1, "1 Structure · 2 Liquidity", text_color = color.white, bgcolor = bg)
    table.cell(hud, 0, 2, "Internal", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 2, f_trendName(stInternal.trend), text_color = stInternal.trend == TREND_BULL ? bullBosCol : stInternal.trend == TREND_BEAR ? bearBosCol : color.gray, bgcolor = bg)
    table.cell(hud, 0, 3, "External", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 3, f_trendName(stExternal.trend), text_color = stExternal.trend == TREND_BULL ? bullBosCol : stExternal.trend == TREND_BEAR ? bearBosCol : color.gray, bgcolor = bg)
    table.cell(hud, 0, 4, "Bias", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 4, f_trendName(ctx.bias), text_color = ctx.bias == TREND_BULL ? bullBosCol : ctx.bias == TREND_BEAR ? bearBosCol : color.gray, bgcolor = bg)
    table.cell(hud, 0, 5, "Prot High", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 5, na(stExternal.protHigh) ? "—" : str.tostring(stExternal.protHigh, format.mintick), text_color = protHighCol, bgcolor = bg)
    table.cell(hud, 0, 6, "Prot Low", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 6, na(stExternal.protLow) ? "—" : str.tostring(stExternal.protLow, format.mintick), text_color = protLowCol, bgcolor = bg)
    table.cell(hud, 0, 7, "Buy Side Liq", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 7, str.tostring(liqEng.activeBSL) + (na(liqEng.nearestBSL) ? "" : " · " + str.tostring(liqEng.nearestBSL, format.mintick)), text_color = bslCol, bgcolor = bg)
    table.cell(hud, 0, 8, "Sell Side Liq", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 8, str.tostring(liqEng.activeSSL) + (na(liqEng.nearestSSL) ? "" : " · " + str.tostring(liqEng.nearestSSL, format.mintick)), text_color = sslCol, bgcolor = bg)
    table.cell(hud, 0, 9, "Nearest Liq", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 9, na(liqEng.nearestLiq) ? "—" : str.tostring(liqEng.nearestLiq, format.mintick), text_color = color.white, bgcolor = bg)
    table.cell(hud, 0, 10, "Liq Score", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 10, na(liqEng.bestScore) ? "—" : str.tostring(liqEng.bestScore, "#.##") + "%", text_color = color.white, bgcolor = bg)
    table.cell(hud, 0, 11, "Last Sweep", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 11, liqEng.lastSweepDir == TREND_BULL ? "Bullish" : liqEng.lastSweepDir == TREND_BEAR ? "Bearish" : "—", text_color = liqEng.lastSweepDir == TREND_BULL ? sweepBullCol : liqEng.lastSweepDir == TREND_BEAR ? sweepBearCol : color.gray, bgcolor = bg)
