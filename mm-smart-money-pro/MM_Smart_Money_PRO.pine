//@version=6
indicator(
     title            = "MM Smart Money PRO — Structure Engine",
     shorttitle       = "MM SM PRO M1",
     overlay          = true,
     max_lines_count  = 500,
     max_labels_count = 500,
     max_boxes_count  = 100,
     max_bars_back    = 5000)

// ============================================================================
// INPUTS
// ============================================================================
string GRP_INT = "Internal Structure"
int  iLeft           = input.int(3, "Internal Left Bars", minval = 1, maxval = 50, group = GRP_INT)
int  iRight          = input.int(3, "Internal Right Bars", minval = 1, maxval = 50, group = GRP_INT)
bool showInt         = input.bool(true, "Show Internal Structure", group = GRP_INT)
bool showIntSwings   = input.bool(false, "Show Internal Swing Markers", group = GRP_INT)

string GRP_EXT = "External Structure"
int  eLeft           = input.int(8, "External Left Bars", minval = 1, maxval = 100, group = GRP_EXT)
int  eRight          = input.int(8, "External Right Bars", minval = 1, maxval = 100, group = GRP_EXT)
bool showExt         = input.bool(true, "Show External Structure", group = GRP_EXT)
bool showExtSwings   = input.bool(true, "Show External Swing Markers", group = GRP_EXT)

string GRP_EVT = "Structure Events"
bool showBOS         = input.bool(true, "Show BOS", group = GRP_EVT)
bool showCHoCH       = input.bool(true, "Show CHoCH", group = GRP_EVT)
bool showMSS         = input.bool(true, "Show MSS", group = GRP_EVT)
bool showHHLL        = input.bool(true, "Show HH / HL / LH / LL Labels", group = GRP_EVT)
bool showProt        = input.bool(true, "Show Protected High / Low", group = GRP_EVT)
string breakBasis    = input.string("Close", "Break Confirmation", options = ["Close", "Wick"], group = GRP_EVT, tooltip = "Evaluated on the closed candle only. Close = body close through level. Wick = high/low of the closed bar.")

string GRP_VIS = "Visuals & Limits"
color bullBosCol     = input.color(color.new(#089981, 0), "Bullish BOS", group = GRP_VIS)
color bearBosCol     = input.color(color.new(#f23645, 0), "Bearish BOS", group = GRP_VIS)
color bullChochCol   = input.color(color.new(#00bcd4, 0), "Bullish CHoCH", group = GRP_VIS)
color bearChochCol   = input.color(color.new(#e91e63, 0), "Bearish CHoCH", group = GRP_VIS)
color bullMssCol     = input.color(color.new(#2962ff, 0), "Bullish MSS", group = GRP_VIS)
color bearMssCol     = input.color(color.new(#ff6d00, 0), "Bearish MSS", group = GRP_VIS)
color bullStructCol  = input.color(color.new(#089981, 45), "Bullish Structure Line", group = GRP_VIS)
color bearStructCol  = input.color(color.new(#f23645, 45), "Bearish Structure Line", group = GRP_VIS)
color protHighCol    = input.color(color.new(#f23645, 0), "Protected High", group = GRP_VIS)
color protLowCol     = input.color(color.new(#089981, 0), "Protected Low", group = GRP_VIS)
int  lineWidthInt    = input.int(1, "Internal Line Width", minval = 1, maxval = 4, group = GRP_VIS)
int  lineWidthExt    = input.int(2, "External Line Width", minval = 1, maxval = 4, group = GRP_VIS)
int  maxSwingsKeep   = input.int(40, "Max Stored Swings / Layer", minval = 10, maxval = 100, group = GRP_VIS)
bool showHud         = input.bool(true, "Show Module HUD", group = GRP_VIS)

// ============================================================================
// CONSTANTS
// ============================================================================
const int SWING_HIGH    = 1
const int SWING_LOW     = -1

const int TREND_FLAT    = 0
const int TREND_BULLISH = 1
const int TREND_BEARISH = -1

const int EVT_NONE  = 0
const int EVT_BOS   = 1
const int EVT_CHOCH = 2
const int EVT_MSS   = 3

const int CLASS_NONE = 0
const int CLASS_HH   = 1
const int CLASS_HL   = 2
const int CLASS_LH   = 3
const int CLASS_LL   = 4

// ============================================================================
// TYPES
// ============================================================================
type SwingPoint
    float price
    int   barIndex
    int   kind
    int   classification
    bool  broken
    bool  isProtected
    bool  protLabeled
    line  levelLine
    label swingLabel
    label protLabel

type StructureLayer
    array<SwingPoint> swings
    int   trend
    float lastHighPrice
    int   lastHighBar
    float lastLowPrice
    int   lastLowBar
    float activeHigh
    int   activeHighBar
    float activeLow
    int   activeLowBar
    int   lastEventBar
    int   lastEventType
    int   lastEventDir
    int   lastClassBar
    float protHighPrice
    int   protHighBar
    float protLowPrice
    int   protLowBar

// ============================================================================
// FACTORY
// ============================================================================
newLayer() =>
    StructureLayer.new(
         array.new<SwingPoint>(),
         TREND_FLAT,
         na, na, na, na,
         na, na, na, na,
         na, EVT_NONE, TREND_FLAT, na,
         na, na, na, na)

var StructureLayer internalLayer = newLayer()
var StructureLayer externalLayer = newLayer()

// ============================================================================
// HELPERS
// ============================================================================
bullBreak(float level) =>
    breakBasis == "Close" ? close > level : high > level

bearBreak(float level) =>
    breakBasis == "Close" ? close < level : low < level

f_className(int c) =>
    switch c
        CLASS_HH => "HH"
        CLASS_HL => "HL"
        CLASS_LH => "LH"
        CLASS_LL => "LL"
        => ""

f_eventName(int e) =>
    switch e
        EVT_BOS   => "BOS"
        EVT_CHOCH => "CHoCH"
        EVT_MSS   => "MSS"
        => ""

f_eventColor(int e, int dir) =>
    dir == TREND_BULLISH ? (e == EVT_BOS ? bullBosCol : e == EVT_CHOCH ? bullChochCol : bullMssCol) : (e == EVT_BOS ? bearBosCol : e == EVT_CHOCH ? bearChochCol : bearMssCol)

f_trimSwings(StructureLayer layer) =>
    while array.size(layer.swings) > maxSwingsKeep
        SwingPoint old = array.shift(layer.swings)
        if not na(old.levelLine)
            line.delete(old.levelLine)
        if not na(old.swingLabel)
            label.delete(old.swingLabel)
        if not na(old.protLabel)
            label.delete(old.protLabel)

f_classifyHigh(StructureLayer layer, float price) =>
    int cls = CLASS_NONE
    if not na(layer.lastHighPrice)
        cls := price > layer.lastHighPrice ? CLASS_HH : CLASS_LH
    cls

f_classifyLow(StructureLayer layer, float price) =>
    int cls = CLASS_NONE
    if not na(layer.lastLowPrice)
        cls := price > layer.lastLowPrice ? CLASS_HL : CLASS_LL
    cls

f_markKindBroken(StructureLayer layer, int kind) =>
    int sz = array.size(layer.swings)
    if sz > 0
        for i = 0 to sz - 1
            SwingPoint s = array.get(layer.swings, i)
            if s.kind == kind and not s.broken
                bool crossed = kind == SWING_HIGH ? bullBreak(s.price) : bearBreak(s.price)
                if crossed
                    s.broken := true
                    s.isProtected := false
                    if not na(s.levelLine)
                        line.set_x2(s.levelLine, bar_index)
                    array.set(layer.swings, i, s)

f_refreshProtection(StructureLayer layer, bool allowDraw) =>
    float uh = na
    int   uhBar = na
    float ul = na
    int   ulBar = na
    int sz = array.size(layer.swings)
    if sz > 0
        for i = sz - 1 to 0
            SwingPoint s = array.get(layer.swings, i)
            if s.kind == SWING_HIGH and not s.broken and na(uh)
                uh := s.price
                uhBar := s.barIndex
            if s.kind == SWING_LOW and not s.broken and na(ul)
                ul := s.price
                ulBar := s.barIndex
            if not na(uh) and not na(ul)
                break

    layer.protHighPrice := layer.trend == TREND_BEARISH ? uh : na
    layer.protHighBar   := layer.trend == TREND_BEARISH ? uhBar : na
    layer.protLowPrice  := layer.trend == TREND_BULLISH ? ul : na
    layer.protLowBar    := layer.trend == TREND_BULLISH ? ulBar : na

    if sz > 0
        for i = 0 to sz - 1
            SwingPoint s = array.get(layer.swings, i)
            bool prot = false
            if not s.broken
                if layer.trend == TREND_BEARISH and s.kind == SWING_HIGH and s.barIndex == layer.protHighBar
                    prot := true
                if layer.trend == TREND_BULLISH and s.kind == SWING_LOW and s.barIndex == layer.protLowBar
                    prot := true
            s.isProtected := prot
            if allowDraw and showProt and prot and not s.protLabeled
                s.protLabel := label.new(
                     s.barIndex, s.price,
                     s.kind == SWING_HIGH ? "PH" : "PL",
                     xloc = xloc.bar_index,
                     yloc = yloc.price,
                     color = color.new(s.kind == SWING_HIGH ? protHighCol : protLowCol, 100),
                     textcolor = s.kind == SWING_HIGH ? protHighCol : protLowCol,
                     style = s.kind == SWING_HIGH ? label.style_label_down : label.style_label_up,
                     size = size.tiny)
                s.protLabeled := true
            array.set(layer.swings, i, s)

f_extendUnbrokenLines(StructureLayer layer) =>
    int sz = array.size(layer.swings)
    if sz > 0
        for i = 0 to sz - 1
            SwingPoint s = array.get(layer.swings, i)
            if not s.broken and not na(s.levelLine)
                line.set_x2(s.levelLine, bar_index)

// ============================================================================
// SWING REGISTRATION
// ============================================================================
f_registerSwing(StructureLayer layer, float price, int pivotBar, int kind, bool showLayer, bool showMarkers, color lineCol, int lineW) =>
    int cls = kind == SWING_HIGH ? f_classifyHigh(layer, price) : f_classifyLow(layer, price)

    line ln = na
    if showLayer
        ln := line.new(pivotBar, price, bar_index, price, xloc = xloc.bar_index, color = lineCol, width = lineW)

    label lb = na
    if showLayer and showMarkers and showHHLL and cls != CLASS_NONE
        if na(layer.lastClassBar) or layer.lastClassBar != pivotBar
            lb := label.new(
                 pivotBar, price, f_className(cls),
                 xloc = xloc.bar_index,
                 yloc = yloc.price,
                 color = color.new(lineCol, 100),
                 textcolor = lineCol,
                 style = kind == SWING_HIGH ? label.style_label_down : label.style_label_up,
                 size = size.tiny)
            layer.lastClassBar := pivotBar

    SwingPoint sp = SwingPoint.new(price, pivotBar, kind, cls, false, false, false, ln, lb, na)
    array.push(layer.swings, sp)
    f_trimSwings(layer)

    if kind == SWING_HIGH
        layer.lastHighPrice := price
        layer.lastHighBar   := pivotBar
        layer.activeHigh    := price
        layer.activeHighBar := pivotBar
    else
        layer.lastLowPrice := price
        layer.lastLowBar   := pivotBar
        layer.activeLow    := price
        layer.activeLowBar := pivotBar

    if layer.trend == TREND_FLAT
        if cls == CLASS_HH or cls == CLASS_HL
            layer.trend := TREND_BULLISH
        else if cls == CLASS_LL or cls == CLASS_LH
            layer.trend := TREND_BEARISH

    f_refreshProtection(layer, showLayer)

// ============================================================================
// BREAK ENGINE — BOS / CHoCH / MSS
// ============================================================================
f_detectBreaks(StructureLayer layer, bool isExternal, bool showLayer) =>
    int evt = EVT_NONE
    int dir = TREND_FLAT

    if barstate.isconfirmed
        bool didBull = not na(layer.activeHigh) and bullBreak(layer.activeHigh)
        bool didBear = not na(layer.activeLow) and bearBreak(layer.activeLow)

        if didBull and didBear
            if close >= open
                didBear := false
            else
                didBull := false

        if didBull or didBear
            dir := didBull ? TREND_BULLISH : TREND_BEARISH

            if layer.trend == TREND_FLAT
                evt := EVT_BOS
            else if didBull
                evt := layer.trend == TREND_BULLISH ? EVT_BOS : (isExternal ? EVT_MSS : EVT_CHOCH)
            else
                evt := layer.trend == TREND_BEARISH ? EVT_BOS : (isExternal ? EVT_MSS : EVT_CHOCH)

            if na(layer.lastEventBar) or layer.lastEventBar != bar_index
                layer.lastEventBar  := bar_index
                layer.lastEventType := evt
                layer.lastEventDir  := dir
                layer.trend         := dir

                if didBull
                    f_markKindBroken(layer, SWING_HIGH)
                    layer.activeHigh    := na
                    layer.activeHighBar := na
                else
                    f_markKindBroken(layer, SWING_LOW)
                    layer.activeLow    := na
                    layer.activeLowBar := na

                f_refreshProtection(layer, showLayer)

                bool drawIt = showLayer and ((evt == EVT_BOS and showBOS) or (evt == EVT_CHOCH and showCHoCH) or (evt == EVT_MSS and showMSS))
                if drawIt
                    string txt = (isExternal ? "" : "i") + f_eventName(evt)
                    color  col = f_eventColor(evt, dir)
                    label.new(
                         bar_index,
                         dir == TREND_BULLISH ? low : high,
                         txt,
                         xloc = xloc.bar_index,
                         yloc = yloc.price,
                         color = color.new(col, 100),
                         textcolor = col,
                         style = dir == TREND_BULLISH ? label.style_label_up : label.style_label_down,
                         size = size.small)

        if showLayer
            f_extendUnbrokenLines(layer)

    [evt, dir]

// ============================================================================
// PIVOT SERIES
// ============================================================================
float iPivotH = ta.pivothigh(high, iLeft, iRight)
float iPivotL = ta.pivotlow(low, iLeft, iRight)
float ePivotH = ta.pivothigh(high, eLeft, eRight)
float ePivotL = ta.pivotlow(low, eLeft, eRight)

int iEvt = EVT_NONE
int iDir = TREND_FLAT
int eEvt = EVT_NONE
int eDir = TREND_FLAT

// ============================================================================
// MAIN LOOP — confirmed candles only
// ============================================================================
if barstate.isconfirmed
    if not na(iPivotH)
        f_registerSwing(internalLayer, iPivotH, bar_index - iRight, SWING_HIGH, showInt, showIntSwings, bearStructCol, lineWidthInt)
    if not na(iPivotL)
        f_registerSwing(internalLayer, iPivotL, bar_index - iRight, SWING_LOW, showInt, showIntSwings, bullStructCol, lineWidthInt)

    if not na(ePivotH)
        f_registerSwing(externalLayer, ePivotH, bar_index - eRight, SWING_HIGH, showExt, showExtSwings, bearStructCol, lineWidthExt)
    if not na(ePivotL)
        f_registerSwing(externalLayer, ePivotL, bar_index - eRight, SWING_LOW, showExt, showExtSwings, bullStructCol, lineWidthExt)

    [ie, idir] = f_detectBreaks(internalLayer, false, showInt)
    [ee, edir] = f_detectBreaks(externalLayer, true, showExt)
    iEvt := ie
    iDir := idir
    eEvt := ee
    eDir := edir

// ============================================================================
// DATA WINDOW EXPORTS
// ============================================================================
plot(internalLayer.trend, title = "Internal Trend", display = display.data_window)
plot(externalLayer.trend, title = "External Trend", display = display.data_window)
plot(internalLayer.activeHigh, title = "Internal Active High", display = display.data_window)
plot(internalLayer.activeLow, title = "Internal Active Low", display = display.data_window)
plot(externalLayer.activeHigh, title = "External Active High", display = display.data_window)
plot(externalLayer.activeLow, title = "External Active Low", display = display.data_window)
plot(externalLayer.protHighPrice, title = "Protected High", display = display.data_window)
plot(externalLayer.protLowPrice, title = "Protected Low", display = display.data_window)
plot(iEvt, title = "Internal Event", display = display.data_window)
plot(eEvt, title = "External Event", display = display.data_window)

// ============================================================================
// ALERTS — structure foundation
// ============================================================================
alertcondition(iEvt == EVT_BOS and iDir == TREND_BULLISH, "Internal Bullish BOS", "MM SM PRO: Internal Bullish BOS")
alertcondition(iEvt == EVT_BOS and iDir == TREND_BEARISH, "Internal Bearish BOS", "MM SM PRO: Internal Bearish BOS")
alertcondition(iEvt == EVT_CHOCH and iDir == TREND_BULLISH, "Internal Bullish CHoCH", "MM SM PRO: Internal Bullish CHoCH")
alertcondition(iEvt == EVT_CHOCH and iDir == TREND_BEARISH, "Internal Bearish CHoCH", "MM SM PRO: Internal Bearish CHoCH")
alertcondition(eEvt == EVT_BOS and eDir == TREND_BULLISH, "External Bullish BOS", "MM SM PRO: External Bullish BOS")
alertcondition(eEvt == EVT_BOS and eDir == TREND_BEARISH, "External Bearish BOS", "MM SM PRO: External Bearish BOS")
alertcondition(eEvt == EVT_MSS and eDir == TREND_BULLISH, "Bullish MSS", "MM SM PRO: Bullish MSS")
alertcondition(eEvt == EVT_MSS and eDir == TREND_BEARISH, "Bearish MSS", "MM SM PRO: Bearish MSS")

// ============================================================================
// MODULE HUD
// ============================================================================
var table hud = table.new(position.top_right, 2, 6, border_width = 1)

if showHud and barstate.isconfirmed and barstate.islast
    color bg = color.new(#1e222d, 10)
    table.cell(hud, 0, 0, "MM Smart Money PRO", text_color = color.white, bgcolor = color.new(#1e222d, 0), text_halign = text.align_center)
    table.merge_cells(hud, 0, 0, 1, 0)
    table.cell(hud, 0, 1, "Module", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 1, "1 · Structure", text_color = color.white, bgcolor = bg)
    table.cell(hud, 0, 2, "Internal", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 2, internalLayer.trend == TREND_BULLISH ? "Bullish" : internalLayer.trend == TREND_BEARISH ? "Bearish" : "Flat", text_color = internalLayer.trend == TREND_BULLISH ? bullBosCol : internalLayer.trend == TREND_BEARISH ? bearBosCol : color.gray, bgcolor = bg)
    table.cell(hud, 0, 3, "External", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 3, externalLayer.trend == TREND_BULLISH ? "Bullish" : externalLayer.trend == TREND_BEARISH ? "Bearish" : "Flat", text_color = externalLayer.trend == TREND_BULLISH ? bullBosCol : externalLayer.trend == TREND_BEARISH ? bearBosCol : color.gray, bgcolor = bg)
    table.cell(hud, 0, 4, "Prot High", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 4, na(externalLayer.protHighPrice) ? "—" : str.tostring(externalLayer.protHighPrice, format.mintick), text_color = protHighCol, bgcolor = bg)
    table.cell(hud, 0, 5, "Prot Low", text_color = color.gray, bgcolor = bg)
    table.cell(hud, 1, 5, na(externalLayer.protLowPrice) ? "—" : str.tostring(externalLayer.protLowPrice, format.mintick), text_color = protLowCol, bgcolor = bg)
